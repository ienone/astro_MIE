---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ImageLightbox from "../components/ImageLightbox.astro";
import PageEffects from "../components/PageEffects.astro";
import SearchOverlay from "../components/SearchOverlay.astro";
import { siteConfig } from "../lib/site";
import "katex/dist/katex.min.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string | { src: string };
  type?: "website" | "article";
  currentSection?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.assets.homeBackground,
  type = "website",
  currentSection
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.name}`;
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const imageSrc = typeof image === "string" ? image : image.src;
const ogImage = imageSrc.startsWith("http") ? imageSrc : new URL(imageSrc, siteUrl).toString();
const defaultAppearance = siteConfig.theme?.defaultAppearance ?? "light";
const autoSwitchAppearance = siteConfig.theme?.autoSwitchAppearance !== false;
const headerLayout = siteConfig.theme?.header?.layout ?? "fixed";
const searchEnabled = siteConfig.features?.search !== false;
const imageZoomEnabled = siteConfig.features?.imageZoom !== false;
const verification = siteConfig.verification ?? {};
---

<!doctype html>
<html
  lang={siteConfig.language || "en"}
  data-default-appearance={defaultAppearance}
  data-auto-switch-appearance={String(autoSwitchAppearance)}
  data-header-layout={headerLayout}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={siteConfig.branding.favicon} sizes="any" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {verification.google && <meta name="google-site-verification" content={verification.google} />}
    {verification.bing && <meta name="msvalidate.01" content={verification.bing} />}
    {verification.pinterest && <meta name="p:domain_verify" content={verification.pinterest} />}
    {verification.yandex && <meta name="yandex-verification" content={verification.yandex} />}
    {verification.fediverse && <meta name="fediverse:creator" content={verification.fediverse} />}
    <meta name="theme-color" content="#f8f3e7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171b18" media="(prefers-color-scheme: dark)" />
    <ClientRouter fallback="animate" />
  </head>
  <body>
    <script is:inline>
      function applyStoredTheme() {
        const storedTheme = localStorage.getItem("theme");
        const defaultAppearance = document.documentElement.dataset.defaultAppearance || "light";
        const autoSwitchAppearance = document.documentElement.dataset.autoSwitchAppearance !== "false";
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const configuredTheme = defaultAppearance === "dark" ? "dark" : "light";
        const systemTheme = prefersDark ? "dark" : "light";
        const shouldUseSystem = autoSwitchAppearance || defaultAppearance === "system" || defaultAppearance === "auto";
        document.documentElement.dataset.theme = storedTheme || (shouldUseSystem ? systemTheme : configuredTheme);
      }

      applyStoredTheme();

      if (!window.__astroMieThemeBound) {
        window.__astroMieThemeBound = true;
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
          if (!localStorage.getItem("theme")) applyStoredTheme();
        });
        document.addEventListener("astro:after-swap", applyStoredTheme);
        document.addEventListener("astro:page-load", applyStoredTheme);
      }
    </script>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main" data-current-section={currentSection}>
      <slot />
    </main>
    <Footer />
    {searchEnabled && <SearchOverlay />}
    {imageZoomEnabled && <ImageLightbox />}
    <PageEffects />
  </body>
</html>
