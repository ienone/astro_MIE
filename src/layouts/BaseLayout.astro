---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SearchOverlay from "../components/SearchOverlay.astro";
import Icon from "../components/Icon.astro";
import { siteConfig } from "../lib/site";
import "katex/dist/katex.min.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.assets.homeBackground,
  type = "website"
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.name}`;
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image.startsWith("http") ? image : new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang={siteConfig.language || "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={siteConfig.branding.favicon} sizes="any" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f8f3e7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171b18" media="(prefers-color-scheme: dark)" />
    <ClientRouter fallback="animate" />
  </head>
  <body>
    <script is:inline>
      function applyStoredTheme() {
        const storedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = storedTheme || (prefersDark ? "dark" : "light");
      }

      applyStoredTheme();

      if (!window.__astroMieThemeBound) {
        window.__astroMieThemeBound = true;
        document.addEventListener("astro:after-swap", applyStoredTheme);
        document.addEventListener("astro:page-load", applyStoredTheme);
      }
    </script>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <SearchOverlay />
    <dialog class="image-lightbox" data-image-lightbox aria-label="图片预览" data-pagefind-ignore>
      <button class="icon-button" type="button" data-image-lightbox-close aria-label="关闭图片预览"><Icon name="x" /></button>
      <figure>
        <img data-image-lightbox-image alt="" />
        <figcaption data-image-lightbox-caption></figcaption>
      </figure>
    </dialog>
    <template data-code-copy-icon><Icon name="copy" /></template>
    <script is:inline>
      function setupRevealMotion() {
        const revealTargets = document.querySelectorAll(
          ".home-hero, .article-hero, .page-header, .content-section, .post-card, .term-card, .archive-item, .article-main > :not(script)"
        );

        revealTargets.forEach((element, index) => {
          if (!(element instanceof HTMLElement)) return;
          if (element.dataset.reveal === "ready") return;
          element.dataset.reveal = "ready";
          element.style.setProperty("--reveal-index", String(index % 8));
        });

        if (!("IntersectionObserver" in window)) {
          revealTargets.forEach((element) => element instanceof HTMLElement && element.classList.add("is-visible"));
          return;
        }

        window.__astroMieRevealObserver ??= new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -8%", threshold: 0.12 }
        );

        revealTargets.forEach((element) => {
          if (!(element instanceof HTMLElement) || element.classList.contains("is-visible")) return;
          window.__astroMieRevealObserver.observe(element);
        });
      }

      function enhanceCodeBlocks() {
        const iconTemplate = document.querySelector("[data-code-copy-icon]");

        document.querySelectorAll("pre[data-language]").forEach((pre) => {
          if (!(pre instanceof HTMLElement) || pre.dataset.enhanced === "true") return;
          pre.dataset.enhanced = "true";
          const language = pre.dataset.language || "text";
          pre.setAttribute("aria-label", `${language} code block`);

          const button = document.createElement("button");
          button.type = "button";
          button.className = "code-copy";
          button.dataset.codeCopy = "";
          button.setAttribute("aria-label", "Copy code");
          if (iconTemplate instanceof HTMLTemplateElement) {
            button.append(iconTemplate.content.cloneNode(true));
          } else {
            button.textContent = "Copy";
          }
          pre.append(button);
        });
      }

      function setupArticleReading() {
        const article = document.querySelector("[data-article-shell]");
        const progress = document.querySelector("[data-reading-progress]");
        const headings = [...document.querySelectorAll(".article-main .prose h2[id], .article-main .prose h3[id]")];
        const tocLinks = [...document.querySelectorAll("[data-toc-link]")];

        function setActiveHeading(activeId) {
          tocLinks.forEach((link) => {
            if (!(link instanceof HTMLAnchorElement)) return;
            const isActive = decodeURIComponent(link.hash.slice(1)) === activeId;
            link.toggleAttribute("aria-current", isActive);
            if (isActive) {
              link.setAttribute("aria-current", "location");
              const group = link.closest(".toc-group");
              if (group instanceof HTMLDetailsElement) group.open = true;
            }
          });
        }

        window.__astroMieUpdateArticleState = () => {
          if (!(article instanceof HTMLElement)) {
            if (progress instanceof HTMLElement) progress.style.setProperty("--reading-progress", "0");
            return;
          }

          if (progress instanceof HTMLElement) {
            const top = article.getBoundingClientRect().top + window.scrollY;
            const bottom = top + article.offsetHeight;
            const distance = Math.max(1, bottom - top - window.innerHeight);
            const ratio = Math.min(1, Math.max(0, (window.scrollY - top) / distance));
            progress.style.setProperty("--reading-progress", String(ratio));
          }

          if (!headings.length || !tocLinks.length) return;

          const threshold = window.scrollY + 160;
          let active = headings[0];
          for (const heading of headings) {
            if (!(heading instanceof HTMLElement)) continue;
            const offset = heading.getBoundingClientRect().top + window.scrollY;
            if (offset <= threshold) active = heading;
            else break;
          }

          if (active instanceof HTMLElement) setActiveHeading(active.id);
        };

        window.__astroMieUpdateArticleState();
      }

      function getImageCaption(image) {
        const figure = image.closest("figure");
        const caption = figure?.querySelector("figcaption")?.textContent?.trim();
        return caption || image.alt || "";
      }

      function resetLightboxTransitionName(source, preview) {
        window.setTimeout(() => {
          if (source instanceof HTMLElement) source.style.viewTransitionName = "";
          if (preview instanceof HTMLElement) preview.style.viewTransitionName = "";
        }, 80);
      }

      function openImageLightbox(source) {
        const dialog = document.querySelector("[data-image-lightbox]");
        const preview = document.querySelector("[data-image-lightbox-image]");
        const caption = document.querySelector("[data-image-lightbox-caption]");
        if (!(dialog instanceof HTMLDialogElement) || !(preview instanceof HTMLImageElement)) return;

        window.__astroMieLightboxSource = source;
        preview.src = source.currentSrc || source.src;
        preview.alt = source.alt || "";
        const captionText = getImageCaption(source);
        if (caption instanceof HTMLElement) {
          caption.textContent = captionText;
          caption.hidden = !captionText;
        }

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        delete dialog.dataset.closing;

        if (!document.startViewTransition || reduceMotion) {
          dialog.showModal();
          return;
        }

        source.style.viewTransitionName = "article-lightbox-image";
        preview.style.viewTransitionName = "article-lightbox-image";
        const transition = document.startViewTransition(() => dialog.showModal());
        transition.finished.finally(() => resetLightboxTransitionName(source, preview));
      }

      function closeImageLightbox() {
        const dialog = document.querySelector("[data-image-lightbox]");
        const preview = document.querySelector("[data-image-lightbox-image]");
        const source = window.__astroMieLightboxSource;
        if (!(dialog instanceof HTMLDialogElement) || !dialog.open || dialog.dataset.closing === "true") return;

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        dialog.dataset.closing = "true";

        const finish = () => {
          if (dialog.open) dialog.close();
          delete dialog.dataset.closing;
        };

        if (!document.startViewTransition || reduceMotion || !(source instanceof HTMLImageElement) || !(preview instanceof HTMLImageElement)) {
          window.setTimeout(finish, 180);
          return;
        }

        source.style.viewTransitionName = "article-lightbox-image";
        preview.style.viewTransitionName = "article-lightbox-image";
        const transition = document.startViewTransition(finish);
        transition.finished.finally(() => resetLightboxTransitionName(source, preview));
      }

      function setupImageLightbox() {
        const dialog = document.querySelector("[data-image-lightbox]");
        if (dialog instanceof HTMLDialogElement && dialog.dataset.lightboxReady !== "true") {
          dialog.dataset.lightboxReady = "true";
          dialog.addEventListener("click", (event) => {
            if (event.target === dialog) closeImageLightbox();
          });
          dialog.addEventListener("cancel", (event) => {
            event.preventDefault();
            closeImageLightbox();
          });
          dialog.querySelector("[data-image-lightbox-close]")?.addEventListener("click", closeImageLightbox);
        }

        document.querySelectorAll(".article-main .prose img").forEach((image) => {
          if (!(image instanceof HTMLImageElement) || image.dataset.zoomReady === "true") return;
          image.dataset.zoomReady = "true";
          image.tabIndex = 0;
          image.setAttribute("role", "button");
          image.setAttribute("aria-label", image.alt ? `预览图片：${image.alt}` : "预览图片");
          image.addEventListener("click", () => openImageLightbox(image));
          image.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            openImageLightbox(image);
          });
        });
      }

      function initPageEffects() {
        enhanceCodeBlocks();
        setupRevealMotion();
        setupArticleReading();
        setupImageLightbox();
      }

      if (!window.__astroMieBaseBound) {
        window.__astroMieBaseBound = true;

        document.addEventListener("click", async (event) => {
          const button = event.target instanceof Element ? event.target.closest("[data-code-copy]") : null;
          if (!(button instanceof HTMLButtonElement)) return;
          const pre = button.closest("pre");
          const code = pre?.querySelector("code")?.textContent || "";
          if (!code) return;

          await navigator.clipboard.writeText(code);
          button.dataset.copied = "true";
          window.setTimeout(() => delete button.dataset.copied, 1200);
        });

        window.addEventListener(
          "scroll",
          () => {
            if (window.__astroMieArticleRaf) window.cancelAnimationFrame(window.__astroMieArticleRaf);
            window.__astroMieArticleRaf = window.requestAnimationFrame(() => window.__astroMieUpdateArticleState?.());
          },
          { passive: true }
        );
        window.addEventListener("resize", () => window.__astroMieUpdateArticleState?.());

        document.addEventListener("astro:page-load", initPageEffects);
        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", initPageEffects, { once: true });
      }

      initPageEffects();
    </script>
  </body>
</html>
