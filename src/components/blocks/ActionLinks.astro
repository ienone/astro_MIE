---
import MaterialButton from "../material/Button.astro";

interface ActionLink {
  href: string;
  label: string;
  target?: string;
  rel?: string;
}

interface Props {
  links: ActionLink[];
  label?: string;
}

const { links = [], label = "Related links" } = Astro.props;
---

<nav class="action-links" aria-label={label}>
  {
    links.map((link) => {
      const target = link.target ?? (link.href.startsWith("http") ? "_blank" : undefined);
      const rel = link.rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);

      return (
        <MaterialButton class="action-links__item" href={link.href} target={target} rel={rel}>
          {link.label}
        </MaterialButton>
      );
    })
  }
</nav>

<style>
  .action-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 1.5rem 0;
  }

  .action-links__item {
    --md-filled-tonal-button-container-color: var(--md-sys-color-primary-container);
    --md-filled-tonal-button-container-height: 42px;
    --md-filled-tonal-button-container-shape: var(--md-sys-shape-corner-full);
    --md-filled-tonal-button-hover-state-layer-color: var(--md-sys-color-primary);
    --md-filled-tonal-button-hover-state-layer-opacity: var(--md-sys-state-hover-opacity);
    --md-filled-tonal-button-label-text-color: var(--md-sys-color-on-primary-container);
    --md-filled-tonal-button-label-text-weight: 700;
    --md-filled-tonal-button-pressed-state-layer-color: var(--md-sys-color-primary);
    --md-filled-tonal-button-pressed-state-layer-opacity: var(--md-sys-state-pressed-opacity);
    transition: transform var(--motion-fast);
  }

  .action-links__item:hover,
  .action-links__item:focus-visible {
    transform: translateY(-1px);
    --md-filled-tonal-button-container-color: color-mix(in srgb, var(--md-sys-color-primary) 18%, var(--md-sys-color-primary-container));
  }
</style>
