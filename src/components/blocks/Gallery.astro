---
import type { ImageMetadata } from "astro";
import OptimizedImage from "../OptimizedImage.astro";

interface ImageItem {
  src: string | ImageMetadata;
  alt?: string;
  caption?: string;
}

interface Props {
  images: ImageItem[];
}

const { images = [] } = Astro.props;
---

<div class="portable-gallery">
  {
    images.map((image) => (
      <figure>
        <OptimizedImage src={image.src} alt={image.alt || ""} loading="lazy" decoding="async" widths={[360, 540, 760]} sizes="(min-width: 680px) 380px, 100vw" />
        {image.caption && <figcaption>{image.caption}</figcaption>}
      </figure>
    ))
  }
</div>
