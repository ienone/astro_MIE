<script>
  // @ts-nocheck
  import { gsap } from "gsap";

  const motionWindow = window;
  const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  const revealSelector = [
    ".home-scene",
    ".article-hero",
    ".page-header",
    ".content-section",
    ".post-card",
    ".term-card",
    ".archive-item",
    ".home-discovery-panel"
  ].join(",");
  const sceneSelector = ["[data-home-scene]", ".article-hero", ".page-header"].join(",");

  const motionState =
    motionWindow.__astroMieScrollMotionState ??
    (motionWindow.__astroMieScrollMotionState = {
      revealItems: [],
      sceneItems: [],
      raf: 0,
      nativeScrollBound: false
    });

  function getScrollState() {
    return (
      motionWindow.__astroMieScroll?.state ?? {
        scroll: window.scrollY,
        limit: Math.max(0, document.documentElement.scrollHeight - window.innerHeight),
        progress: 0,
        velocity: 0,
        direction: 0,
        isScrolling: false
      }
    );
  }

  function clamp(value, min = 0, max = 1) {
    return Math.min(max, Math.max(min, value));
  }

  function cacheElementBox(element) {
    const scrollTop = getScrollState().scroll;
    const rect = element.getBoundingClientRect();
    return {
      top: rect.top + scrollTop,
      bottom: rect.bottom + scrollTop,
      height: rect.height || element.offsetHeight || 1
    };
  }

  function refreshScrollMotionCache() {
    const reduceMotion = reduceMotionQuery.matches;
    document.documentElement.dataset.scrollMotion = reduceMotion ? "reduced" : "gsap";

    motionState.revealItems = [...document.querySelectorAll(revealSelector)]
      .filter((element) => element instanceof HTMLElement)
      .map((element, index) => {
        element.dataset.reveal = "ready";
        element.style.setProperty("--reveal-index", String(index % 8));

        if (reduceMotion) {
          element.classList.add("is-visible");
          gsap.set(element, { clearProps: "opacity,transform,willChange" });
        } else if (!element.classList.contains("is-visible")) {
          gsap.set(element, { autoAlpha: 0, y: 18, scale: 0.985, willChange: "opacity,transform" });
        }

        return { element, ...cacheElementBox(element) };
      });

    motionState.sceneItems = [...document.querySelectorAll(sceneSelector)]
      .filter((element) => element instanceof HTMLElement)
      .map((element) => ({
        element,
        setProgress: gsap.quickTo(element, "--scene-progress", { duration: 0.22, ease: "power2.out" }),
        setCenter: gsap.quickTo(element, "--scene-center", { duration: 0.22, ease: "power2.out" }),
        ...cacheElementBox(element)
      }));

    scheduleScrollMotionUpdate();
  }

  function revealElement(item) {
    const { element } = item;
    if (!(element instanceof HTMLElement) || element.classList.contains("is-visible")) return;

    element.classList.add("is-visible");
    gsap.to(element, {
      autoAlpha: 1,
      y: 0,
      scale: 1,
      duration: 0.56,
      delay: (Number.parseInt(element.style.getPropertyValue("--reveal-index"), 10) % 6) * 0.035,
      ease: "power3.out",
      overwrite: "auto",
      onComplete: () => gsap.set(element, { clearProps: "opacity,transform,willChange" })
    });
  }

  function updateScrollMotion() {
    motionState.raf = 0;

    if (reduceMotionQuery.matches) return;

    const { scroll } = getScrollState();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 1;
    const revealThreshold = scroll + viewportHeight * 0.9;

    motionState.revealItems.forEach((item) => {
      if (item.bottom < scroll || item.top < revealThreshold) revealElement(item);
    });

    motionState.sceneItems.forEach((item) => {
      const progress = clamp((scroll + viewportHeight - item.top) / (viewportHeight + item.height));
      const center = clamp((scroll + viewportHeight * 0.5 - item.top) / item.height);
      item.setProgress(progress);
      item.setCenter(center);
    });
  }

  function scheduleScrollMotionUpdate() {
    if (motionState.raf) return;
    motionState.raf = window.requestAnimationFrame(updateScrollMotion);
  }

  function subscribeScrollMotionToRuntime() {
    if (motionWindow.__astroMieScroll && !motionWindow.__astroMieScrollMotionUnsubscribe) {
      motionWindow.__astroMieScrollMotionUnsubscribe = motionWindow.__astroMieScroll.subscribe(scheduleScrollMotionUpdate);
    }

    if (!motionWindow.__astroMieScroll && !motionState.nativeScrollBound) {
      motionState.nativeScrollBound = true;
      window.addEventListener("scroll", scheduleScrollMotionUpdate, { passive: true });
    }
  }

  function handleScrollMotionResize() {
    window.clearTimeout(motionState.resizeTimer);
    motionState.resizeTimer = window.setTimeout(refreshScrollMotionCache, 80);
  }

  if (!motionWindow.__astroMieScrollMotionBound) {
    motionWindow.__astroMieScrollMotionBound = true;
    document.addEventListener("astro-mie:scroll-ready", subscribeScrollMotionToRuntime);
    document.addEventListener("astro:page-load", refreshScrollMotionCache);
    window.addEventListener("resize", handleScrollMotionResize);

    if (reduceMotionQuery.addEventListener) {
      reduceMotionQuery.addEventListener("change", refreshScrollMotionCache);
    } else {
      reduceMotionQuery.addListener?.(refreshScrollMotionCache);
    }
  }

  subscribeScrollMotionToRuntime();
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", refreshScrollMotionCache, { once: true });
  else refreshScrollMotionCache();
</script>
