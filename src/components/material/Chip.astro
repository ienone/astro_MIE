---
import Icon from "../Icon.astro";

interface Props {
  icon?: string;
  elevated?: boolean;
  class?: string;
  href?: string;
  target?: string;
  style?: Record<string, string> | string;
  [key: string]: unknown;
}

const { icon, elevated = false, class: className, ...attrs } = Astro.props;
const hostClass = ["mie-material-chip", className].filter(Boolean).join(" ");
---

<md-assist-chip {...attrs} class={hostClass} elevated={elevated ? true : undefined}>
  {icon && <span slot="icon" class="mie-material-chip__icon"><Icon name={icon} /></span>}
  <span class="mie-material-chip__content"><slot /></span>
</md-assist-chip>
