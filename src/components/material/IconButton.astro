---
import Icon from "../Icon.astro";

interface Props {
  icon: string;
  class?: string;
  href?: string;
  target?: string;
  type?: "button" | "submit" | "reset";
  "aria-label"?: string;
  "aria-controls"?: string;
  "aria-expanded"?: string;
  title?: string;
  [key: string]: unknown;
}

const {
  icon,
  class: className,
  type = "button",
  "aria-label": ariaLabel,
  "aria-controls": ariaControls,
  "aria-expanded": ariaExpanded,
  title,
  ...attrs
} = Astro.props;
const hostClass = ["mie-material-icon-button", className].filter(Boolean).join(" ");
---

<md-filled-tonal-icon-button
  {...attrs}
  class={hostClass}
  type={type}
  aria-label={ariaLabel}
  aria-controls={ariaControls}
  aria-expanded={ariaExpanded}
  title={title ?? ariaLabel}
>
  <Icon name={icon} />
</md-filled-tonal-icon-button>
