---
interface Term {
  term: string;
  slug: string;
  count: number;
}

interface Props {
  terms: Term[];
  basePath: string;
  showCount?: boolean;
  cardView?: boolean;
}

const { terms, basePath, showCount = true, cardView = false } = Astro.props;
---

<div class:list={["term-grid", { compact: !cardView }]}>
  {
    terms.map((item) => (
      <a class="term-card" href={`${basePath}/${item.slug}/`}>
        <span>{item.term}</span>
        {showCount && <strong>{item.count}</strong>}
      </a>
    ))
  }
</div>
