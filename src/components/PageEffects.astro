<script is:inline>
  // Shared transition protocol:
  // set groups related parts, context/target-context define source and destination,
  // name/group map to View Transition names/classes, runtime lets JS opt elements in.
  function setupRouteTransitionState() {
    let routeTransitionActive = false;
    let clearTimer;
    let routeSharedTransition = "";
    let activeSharedSet = "";
    let activeSourceContext = "";
    let activeTargetContext = "";
    let pendingPreparationEvent;
    const routeMarkedElements = new Set();
    const routeSharedStyleProperties = new Set();

    function setRouteState(state) {
      window.clearTimeout(clearTimer);
      document.documentElement.dataset.routeTransition = state;
    }

    function setRouteSharedTransition(value) {
      routeSharedTransition = value;
      if (value) {
        document.documentElement.dataset.routeSharedTransition = value;
      } else {
        delete document.documentElement.dataset.routeSharedTransition;
      }
    }

    function clearRouteSharedStyleProperties() {
      routeSharedStyleProperties.forEach((property) => document.documentElement.style.removeProperty(property));
      routeSharedStyleProperties.clear();
    }

    function resetRouteSharedTransition() {
      routeMarkedElements.forEach((element) => {
        if (!(element instanceof HTMLElement)) return;
        delete element.dataset.routeSharedActive;
        if (element.dataset.routeSharedRuntime === "true") {
          element.style.viewTransitionName = "";
          if (element.dataset.routeSharedContain) element.style.contain = "";
        }
      });
      routeMarkedElements.clear();
      clearRouteSharedStyleProperties();
      pendingPreparationEvent = undefined;
      setRouteSharedTransition("");
      activeSharedSet = "";
      activeSourceContext = "";
      activeTargetContext = "";
    }

    function clearRouteState() {
      window.clearTimeout(clearTimer);
      clearTimer = window.setTimeout(() => {
        if (routeTransitionActive) return;
        delete document.documentElement.dataset.routeTransition;
        resetRouteSharedTransition();
      }, 720);
    }

    function escapeAttributeValue(value) {
      return String(value).replace(/\\/g, "\\\\").replace(/"/g, '\\"');
    }

    function normalizePropertyPart(value) {
      return String(value).replace(/[^a-zA-Z0-9_-]/g, "-");
    }

    function setRouteSharedStyleProperty(property, value) {
      if (!value) return;
      document.documentElement.style.setProperty(property, value);
      routeSharedStyleProperties.add(property);
    }

    function applySharedMotionOptions(element) {
      const group = element.dataset.routeSharedGroup || element.dataset.routeSharedName;
      if (!group) return;

      const prefix = `--route-shared-${normalizePropertyPart(group)}`;
      const options = {
        duration: "duration",
        backDuration: "back-duration",
        ease: "ease",
        backEase: "back-ease",
        z: "z"
      };

      Object.entries(options).forEach(([datasetKey, cssKey]) => {
        setRouteSharedStyleProperty(`${prefix}-${cssKey}`, element.dataset[`routeShared${datasetKey[0].toUpperCase()}${datasetKey.slice(1)}`]);
      });
    }

    function markRouteElement(element) {
      if (!(element instanceof HTMLElement)) return;
      element.dataset.routeSharedActive = "true";
      if (element.dataset.routeSharedRuntime === "true" && element.dataset.routeSharedName) {
        element.style.viewTransitionName = element.dataset.routeSharedName;
        if (element.dataset.routeSharedContain) element.style.contain = element.dataset.routeSharedContain;
      }
      applySharedMotionOptions(element);
      routeMarkedElements.add(element);
    }

    function setDatasetIfMissing(element, key, value) {
      if (!(element instanceof HTMLElement) || element.dataset[key]) return;
      element.dataset[key] = value;
    }

    function upgradeRouteSharedAliases(root) {
      const searchLink = root.querySelector("[data-search-page-link]");
      if (searchLink instanceof HTMLElement) {
        setDatasetIfMissing(searchLink, "routeSharedTrigger", "search-field");
        setDatasetIfMissing(searchLink, "routeSharedSourceContext", "search-overlay");
        setDatasetIfMissing(searchLink, "routeSharedTargetContext", "search-page");
      }

      const overlayInput = root.querySelector("[data-search-transition-source]");
      if (overlayInput instanceof HTMLElement) {
        overlayInput.dataset.routeShared = "";
        setDatasetIfMissing(overlayInput, "routeSharedSet", "search-field");
        setDatasetIfMissing(overlayInput, "routeSharedName", "site-search-field");
        setDatasetIfMissing(overlayInput, "routeSharedGroup", "site-search-field");
        setDatasetIfMissing(overlayInput, "routeSharedContext", "search-overlay");
        setDatasetIfMissing(overlayInput, "routeSharedTargetContext", "search-page");
        setDatasetIfMissing(overlayInput, "routeSharedRuntime", "true");
        setDatasetIfMissing(overlayInput, "routeSharedContain", "layout paint style");
      }

      const pageInput = root.querySelector("[data-search-page-input]");
      if (pageInput instanceof HTMLElement) {
        pageInput.dataset.routeShared = "";
        setDatasetIfMissing(pageInput, "routeSharedSet", "search-field");
        setDatasetIfMissing(pageInput, "routeSharedName", "site-search-field");
        setDatasetIfMissing(pageInput, "routeSharedGroup", "site-search-field");
        setDatasetIfMissing(pageInput, "routeSharedContext", "search-page");
        setDatasetIfMissing(pageInput, "routeSharedTargetContext", "search-overlay");
        setDatasetIfMissing(pageInput, "routeSharedRuntime", "true");
        setDatasetIfMissing(pageInput, "routeSharedContain", "layout paint style");
      }
    }

    function getSharedItems(root, set, context) {
      if (!set) return [];
      let selector = `[data-route-shared][data-route-shared-set="${escapeAttributeValue(set)}"]`;
      if (context) selector += `[data-route-shared-context="${escapeAttributeValue(context)}"]`;
      return [...root.querySelectorAll(selector)].filter((element) => element instanceof HTMLElement);
    }

    function markSharedItems(root, set, context) {
      const items = getSharedItems(root, set, context);
      items.forEach(markRouteElement);
      return items.length;
    }

    function hasExitShared(root) {
      return Boolean(root.querySelector("[data-route-shared][data-route-shared-exit]"));
    }

    function unmarkRouteElements() {
      routeMarkedElements.forEach((element) => {
        if (!(element instanceof HTMLElement)) return;
        delete element.dataset.routeSharedActive;
        if (element.dataset.routeSharedRuntime === "true") {
          element.style.viewTransitionName = "";
          if (element.dataset.routeSharedContain) element.style.contain = "";
        }
      });
      routeMarkedElements.clear();
      clearRouteSharedStyleProperties();
    }

    function getRouteSharedConfig(sourceElement, direction) {
      const trigger = sourceElement instanceof Element ? sourceElement.closest("[data-route-shared-trigger]") : null;
      if (trigger instanceof HTMLElement) {
        const set = trigger.dataset.routeSharedTrigger || trigger.dataset.routeSharedSet || "";
        return {
          set,
          sourceContext: trigger.dataset.routeSharedSourceContext || "",
          targetContext: trigger.dataset.routeSharedTargetContext || "",
          transition: trigger.dataset.routeSharedTransition || "forward"
        };
      }

      const sourceScope = sourceElement instanceof Element ? sourceElement.closest("[data-route-shared-set][data-route-shared-context]") : null;
      if (sourceScope instanceof HTMLElement) {
        const sourceContext = sourceScope.dataset.routeSharedContext || "";
        return {
          set: sourceScope.dataset.routeSharedSet || "",
          sourceContext,
          targetContext: sourceScope.dataset.routeSharedTargetContext || "",
          transition: sourceScope.dataset.routeSharedTransition || (sourceContext === "article" ? "back" : "forward")
        };
      }

      if (direction === "back") {
        const backScope = document.querySelector("[data-route-shared-default-back][data-route-shared-set][data-route-shared-context]");
        if (backScope instanceof HTMLElement) {
          const sourceContext = backScope.dataset.routeSharedContext || "";
          return {
            set: backScope.dataset.routeSharedSet || "",
            sourceContext,
            targetContext: backScope.dataset.routeSharedTargetContext || "",
            transition: backScope.dataset.routeSharedTransition || "back"
          };
        }
      }
    }

    function activateSharedRoute(config) {
      if (!config?.set) return false;

      activeSharedSet = config.set;
      activeSourceContext = config.sourceContext;
      activeTargetContext = config.targetContext;
      setRouteSharedTransition(config.transition || "forward");
      return markSharedItems(document, activeSharedSet, activeSourceContext) > 0;
    }

    function activateDefaultSharedRoute(newDocument) {
      const scopes = [
        ...document.querySelectorAll("[data-route-shared-default-source][data-route-shared-set][data-route-shared-context]"),
        ...document.querySelectorAll("[data-route-shared-default-back][data-route-shared-set][data-route-shared-context]")
      ];

      for (const scope of scopes) {
        if (!(scope instanceof HTMLElement)) continue;
        const set = scope.dataset.routeSharedSet || "";
        const sourceContext = scope.dataset.routeSharedContext || "";
        const targetContext = scope.dataset.routeSharedTargetContext || "";
        if (!set || !targetContext || !getSharedItems(newDocument, set, targetContext).length) continue;

        return activateSharedRoute({
          set,
          sourceContext,
          targetContext,
          transition: scope.dataset.routeSharedTransition || (sourceContext === "article" ? "back" : "forward")
        });
      }

      return false;
    }

    function resolveRouteSharedTransition() {
      const newDocument = pendingPreparationEvent?.newDocument;
      if (!newDocument) return;
      upgradeRouteSharedAliases(newDocument);

      if (!activeSharedSet) activateDefaultSharedRoute(newDocument);

      if (activeSharedSet && markSharedItems(newDocument, activeSharedSet, activeTargetContext) > 0) return;

      unmarkRouteElements();
      activeSharedSet = "";
      activeSourceContext = "";
      activeTargetContext = "";
      setRouteSharedTransition(hasExitShared(document) && !hasExitShared(newDocument) ? "exit" : "suppress");
    }

    document.addEventListener("astro:before-preparation", (event) => {
      routeTransitionActive = true;
      resetRouteSharedTransition();
      upgradeRouteSharedAliases(document);
      pendingPreparationEvent = event;
      setRouteSharedTransition("suppress");

      const sourceElement = event.sourceElement instanceof Element ? event.sourceElement : null;
      activateSharedRoute(getRouteSharedConfig(sourceElement, event.direction));

      setRouteState("loading");
      event.signal?.addEventListener(
        "abort",
        () => {
          routeTransitionActive = false;
          pendingPreparationEvent = undefined;
          clearRouteState();
        },
        { once: true }
      );
    });

    document.addEventListener("astro:after-preparation", () => {
      resolveRouteSharedTransition();
      if (routeTransitionActive) setRouteState("ready");
    });

    document.addEventListener("astro:before-swap", (event) => {
      if (routeTransitionActive) setRouteState("swapping");
      if (routeSharedTransition) event.newDocument.documentElement.dataset.routeSharedTransition = routeSharedTransition;
    });

    document.addEventListener("astro:after-swap", () => {
      if (!routeTransitionActive) return;
      setRouteState("settling");
    });

    document.addEventListener("astro:page-load", () => {
      if (!routeTransitionActive) return;
      routeTransitionActive = false;
      clearRouteState();
    });
  }

  function setupRevealMotion() {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealTargets = document.querySelectorAll(
      ".home-hero, .article-hero, .page-header, .content-section, .post-card, .term-card, .archive-item"
    );

    const canObserve = !reduceMotion && "IntersectionObserver" in window;

    if (canObserve) {
      window.__astroMieRevealObserver ??= new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) return;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          });
        },
        { rootMargin: "0px 0px -8%", threshold: 0.12 }
      );
    }

    revealTargets.forEach((element, index) => {
      if (!(element instanceof HTMLElement)) return;
      if (element.dataset.reveal === "ready") return;

      const rect = element.getBoundingClientRect();
      const initiallyVisible = rect.top < window.innerHeight * 0.92 && rect.bottom > 0;
      const revealImmediately = !canObserve || initiallyVisible;

      if (revealImmediately) element.classList.add("is-visible");
      element.style.setProperty("--reveal-index", String(index % 8));
      element.dataset.reveal = "ready";

      if (!revealImmediately) window.__astroMieRevealObserver?.observe(element);
    });
  }

  function setupArticleTocToggle() {
    const layout = document.querySelector("[data-article-layout]");
    const toggle = document.querySelector("[data-toc-toggle]");
    const label = document.querySelector("[data-toc-toggle-label]");
    const storageKey = "astro-mie-toc-hidden";

    if (!(layout instanceof HTMLElement)) return;

    if (layout.dataset.tocEnabled !== "true") {
      layout.dataset.tocState = "disabled";
      return;
    }

    function readStoredState() {
      try {
        return window.localStorage.getItem(storageKey) === "true";
      } catch {
        return false;
      }
    }

    function writeStoredState(hidden) {
      try {
        window.localStorage.setItem(storageKey, hidden ? "true" : "false");
      } catch {
        // Ignore private-mode storage failures; the per-page toggle still works.
      }
    }

    function applyTocState(hidden) {
      layout.dataset.tocState = hidden ? "hidden" : "visible";
      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute("aria-pressed", hidden ? "true" : "false");
        toggle.setAttribute("aria-label", hidden ? "显示目录" : "隐藏目录");
      }
      if (label instanceof HTMLElement) label.textContent = hidden ? "显示目录" : "沉浸阅读";
    }

    applyTocState(readStoredState());

    if (!(toggle instanceof HTMLButtonElement) || toggle.dataset.tocToggleReady === "true") return;
    toggle.dataset.tocToggleReady = "true";
    toggle.addEventListener("click", () => {
      const hidden = layout.dataset.tocState !== "hidden";
      applyTocState(hidden);
      writeStoredState(hidden);
      window.__astroMieUpdateArticleState?.();
    });
  }

  function setupArticleReading() {
    const article = document.querySelector("[data-article-shell]");
    const progress = document.querySelector("[data-reading-progress]");
    const headings = [...document.querySelectorAll(".article-main .prose h2[id], .article-main .prose h3[id]")];
    const tocLinks = [...document.querySelectorAll("[data-toc-link]")];

    function setActiveHeading(activeId) {
      tocLinks.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        const isActive = decodeURIComponent(link.hash.slice(1)) === activeId;
        link.toggleAttribute("aria-current", isActive);
        if (isActive) {
          link.setAttribute("aria-current", "location");
          const group = link.closest(".toc-group");
          if (group instanceof HTMLDetailsElement) group.open = true;
        }
      });
    }

    window.__astroMieUpdateArticleState = () => {
      if (!(article instanceof HTMLElement)) {
        if (progress instanceof HTMLElement) progress.style.setProperty("--reading-progress", "0");
        return;
      }

      if (progress instanceof HTMLElement) {
        const top = article.getBoundingClientRect().top + window.scrollY;
        const bottom = top + article.offsetHeight;
        const distance = Math.max(1, bottom - top - window.innerHeight);
        const ratio = Math.min(1, Math.max(0, (window.scrollY - top) / distance));
        progress.style.setProperty("--reading-progress", String(ratio));
      }

      if (!headings.length || !tocLinks.length) return;

      const threshold = window.scrollY + 160;
      let active = headings[0];
      for (const heading of headings) {
        if (!(heading instanceof HTMLElement)) continue;
        const offset = heading.getBoundingClientRect().top + window.scrollY;
        if (offset <= threshold) active = heading;
        else break;
      }

      if (active instanceof HTMLElement) setActiveHeading(active.id);
    };

    window.__astroMieUpdateArticleState();
  }

  function initPageEffects() {
    setupRevealMotion();
    setupArticleTocToggle();
    setupArticleReading();
  }

  if (!window.__astroMieBaseBound) {
    window.__astroMieBaseBound = true;
    setupRouteTransitionState();

    window.addEventListener(
      "scroll",
      () => {
        if (window.__astroMieArticleRaf) window.cancelAnimationFrame(window.__astroMieArticleRaf);
        window.__astroMieArticleRaf = window.requestAnimationFrame(() => window.__astroMieUpdateArticleState?.());
      },
      { passive: true }
    );
    window.addEventListener("resize", () => window.__astroMieUpdateArticleState?.());

    document.addEventListener("astro:page-load", initPageEffects);
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", initPageEffects, { once: true });
  }

  initPageEffects();
</script>
