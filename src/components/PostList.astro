---
import PostCard from "./PostCard.astro";
import PostListItem from "./PostListItem.astro";
import { getArchiveGroups, type PostEntry } from "../lib/posts";

interface Props {
  posts: PostEntry[];
  compact?: boolean;
  variant?: "grid" | "compact-grid" | "list";
  showSummary?: boolean;
  showCards?: boolean;
  groupByYear?: boolean;
  cardViewScreenWidth?: boolean;
}

const {
  posts,
  compact = false,
  variant,
  showSummary = true,
  showCards = true,
  groupByYear = false,
  cardViewScreenWidth = false
} = Astro.props;
const archiveGroups = groupByYear ? getArchiveGroups(posts) : [];
const resolvedVariant = !showCards ? "list" : variant ?? (compact ? "compact-grid" : "grid");
const renderCards = resolvedVariant !== "list";
const compactCards = resolvedVariant === "compact-grid";
---

{
  posts.length ? renderCards ? (
    <div class:list={["post-grid", `post-grid--${resolvedVariant}`, { compact: compactCards, "screen-width": cardViewScreenWidth }]}>
      {posts.map((post) => <PostCard post={post} variant={compactCards ? "compact" : "standard"} showSummary={showSummary} />)}
    </div>
  ) : groupByYear ? (
    <div class="archive-list compact">
      {
        archiveGroups.map(([year, yearPosts]) => (
          <section class="archive-year">
            <h2>{year}</h2>
            <div>
              {yearPosts.map((post) => (
                <PostListItem post={post} showSummary={showSummary} />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  ) : (
    <div class="archive-list compact">
      {posts.map((post) => (
        <PostListItem post={post} showSummary={showSummary} />
      ))}
    </div>
  ) : (
    <p class="empty-state">No posts yet.</p>
  )
}
