---
import "photoswipe/style.css";
---

<script>
  import PhotoSwipe from "photoswipe";
  import PhotoSwipeLightbox from "photoswipe/lightbox";

  const lightboxWindow = window as Window &
    typeof globalThis & {
      __astroMiePhotoSwipe?: PhotoSwipeLightbox;
    };

  function getImageCaption(image: HTMLImageElement) {
    const figure = image.closest("figure");
    return figure?.querySelector("figcaption")?.textContent?.trim() || image.alt || "";
  }

  function getImageDimensions(image: HTMLImageElement) {
    const width = Number(image.dataset.pswpWidth || image.getAttribute("width") || image.naturalWidth || 1600);
    const height = Number(image.dataset.pswpHeight || image.getAttribute("height") || image.naturalHeight || 1000);
    return { width, height };
  }

  function getImageData(image: HTMLImageElement) {
    const src = image.currentSrc || image.src;
    const { width, height } = getImageDimensions(image);
    return {
      src,
      msrc: src,
      width,
      height,
      alt: image.alt,
      caption: getImageCaption(image)
    };
  }

  function openPreparedImage(event: Event) {
    const image = event.currentTarget;
    if (!(image instanceof HTMLImageElement)) return;

    const index = Number(image.dataset.lightboxIndex);
    if (!Number.isInteger(index) || index < 0) return;

    event.preventDefault();
    event.stopPropagation();
    lightboxWindow.__astroMiePhotoSwipe?.loadAndOpen(index);
  }

  function prepareLightboxImage(image: HTMLImageElement) {
    image.dataset.zoomReady = "true";
    image.setAttribute("role", "button");
    image.setAttribute("aria-label", image.alt ? `查看图片：${image.alt}` : "查看图片");
    if (!image.hasAttribute("tabindex")) image.tabIndex = 0;
    if (image.dataset.lightboxReady === "true") return;

    image.dataset.lightboxReady = "true";
    image.addEventListener("click", openPreparedImage);
    image.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") return;
      openPreparedImage(event);
    });
  }

  function setupArticleLightbox() {
    lightboxWindow.__astroMiePhotoSwipe?.destroy();
    lightboxWindow.__astroMiePhotoSwipe = undefined;

    const gallery = document.querySelector("[data-article-shell]");
    const imageSelector = ".article-cover img:not([data-lightbox-ignore]), .article-main .prose img:not([data-lightbox-ignore])";
    if (!(gallery instanceof HTMLElement)) return;

    const images = [...gallery.querySelectorAll(imageSelector)].filter((image): image is HTMLImageElement => image instanceof HTMLImageElement);
    if (!images.length) return;
    images.forEach((image, index) => {
      image.dataset.lightboxIndex = String(index);
      prepareLightboxImage(image);
    });

    const lightbox = new PhotoSwipeLightbox({
      dataSource: images.map(getImageData),
      bgOpacity: 0.86,
      wheelToZoom: true,
      initialZoomLevel: "fit",
      secondaryZoomLevel: 1,
      maxZoomLevel: 4,
      paddingFn: (viewportSize) => ({
        top: viewportSize.x < 700 ? 48 : 72,
        bottom: viewportSize.x < 700 ? 72 : 96,
        left: viewportSize.x < 700 ? 12 : 48,
        right: viewportSize.x < 700 ? 12 : 48
      }),
      pswpModule: PhotoSwipe
    });

    lightbox.on("uiRegister", () => {
      lightbox.pswp?.ui?.registerElement({
        name: "download-button",
        order: 8,
        isButton: true,
        tagName: "a",
        html: "下载",
        onInit: (element, pswp) => {
          const link = element as HTMLAnchorElement;
          link.classList.add("pswp__button--download");
          link.setAttribute("download", "");
          link.setAttribute("aria-label", "下载图片");

          const updateLink = () => {
            const src = String(pswp.currSlide?.data?.src || "");
            link.href = src;
            link.download = decodeURIComponent(src.split("/").pop()?.split("?")[0] || "image");
          };

          pswp.on("change", updateLink);
          updateLink();
        }
      });

      lightbox.pswp?.ui?.registerElement({
        name: "caption",
        order: 9,
        isButton: false,
        appendTo: "root",
        html: "",
        onInit: (element, pswp) => {
          element.classList.add("pswp__custom-caption");
          const updateCaption = () => {
            const caption = String(pswp.currSlide?.data?.caption || "");
            element.textContent = caption;
            element.toggleAttribute("hidden", !caption);
          };

          pswp.on("change", updateCaption);
          updateCaption();
        }
      });
    });

    lightbox.init();
    lightboxWindow.__astroMiePhotoSwipe = lightbox;
  }

  document.addEventListener("astro:page-load", setupArticleLightbox);
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", setupArticleLightbox, { once: true });
  else setupArticleLightbox();
</script>
