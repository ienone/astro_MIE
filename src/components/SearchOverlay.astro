---
import Icon from "./Icon.astro";
---

<dialog class="search-overlay" data-search-dialog aria-label="站内搜索" data-pagefind-ignore>
  <div class="search-panel">
    <form class="search-panel-head" method="dialog">
      <label for="site-search">搜索文章</label>
      <button class="icon-button" type="submit" data-search-close aria-label="关闭搜索"><Icon name="x" /></button>
    </form>
    <input id="site-search" data-search-input type="search" autocomplete="off" placeholder="搜索标题、标签或正文" />
    <div class="search-results" data-search-results></div>
  </div>
</dialog>

<script>
  // @ts-nocheck
  const dialog = document.querySelector("[data-search-dialog]");
  const openers = document.querySelectorAll("[data-search-open]");
  const input = document.querySelector("[data-search-input]");
  const results = document.querySelector("[data-search-results]");
  const pageInput = document.querySelector("[data-search-page-input]");
  const pageResults = document.querySelector("[data-search-page-results]");
  const htmlEntities = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" };
  let pagefind;
  let previousFocus;

  const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => htmlEntities[char] ?? char);

  async function ensurePagefind() {
    if (!pagefind) {
      const pagefindPath = "/pagefind/pagefind.js";
      pagefind = import(/* @vite-ignore */ pagefindPath);
    }

    return pagefind;
  }

  function renderMessage(container, message) {
    if (!(container instanceof HTMLElement)) return;
    container.innerHTML = `<p class="search-empty">${escapeHtml(message)}</p>`;
  }

  function renderResults(container, items) {
    if (!(container instanceof HTMLElement)) return;
    if (!items.length) {
      renderMessage(container, "没有找到匹配的文章。");
      return;
    }

    container.innerHTML = items
      .map(
        (item) => {
          const title = item.meta?.title || item.url;
          const excerpt = item.excerpt || escapeHtml(item.meta?.description || item.url);

          return `
          <a class="search-result" href="${escapeHtml(item.url)}">
            <span>${escapeHtml(title)}</span>
            <small>${excerpt}</small>
          </a>
        `;
        }
      )
      .join("");
  }

  function setupSearch(searchInput, searchResults, limit) {
    if (!(searchInput instanceof HTMLInputElement) || !(searchResults instanceof HTMLElement)) return;

    let searchId = 0;

    searchInput.addEventListener("input", async (event) => {
      if (!(event.target instanceof HTMLInputElement)) return;

      const currentSearch = ++searchId;
      const query = event.target.value.trim();
      if (!query) {
        searchResults.innerHTML = "";
        return;
      }

      renderMessage(searchResults, "正在搜索…");

      try {
        const pagefindApi = await ensurePagefind();
        const search = await pagefindApi.search(query, { excerptLength: 30 });
        const items = await Promise.all(search.results.slice(0, limit).map((result) => result.data()));

        if (currentSearch === searchId) renderResults(searchResults, items);
      } catch (error) {
        pagefind = undefined;
        if (currentSearch === searchId) renderMessage(searchResults, "搜索索引尚未生成，请先运行 npm run build。");
      }
    });
  }

  function openSearch() {
    if (!(dialog instanceof HTMLDialogElement)) return;
    previousFocus = document.activeElement;
    if (!dialog.open) dialog.showModal();
    if (input instanceof HTMLInputElement) {
      input.value = "";
      input.focus();
    }
    if (results instanceof HTMLElement) results.innerHTML = "";
  }

  function closeSearch() {
    if (dialog instanceof HTMLDialogElement && dialog.open) dialog.close();
  }

  setupSearch(input, results, 12);
  setupSearch(pageInput, pageResults, 30);
  openers.forEach((button) => button.addEventListener("click", openSearch));
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) closeSearch();
  });
  dialog?.addEventListener("close", () => {
    if (previousFocus instanceof HTMLElement) previousFocus.focus();
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeSearch();
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      openSearch();
    }
  });
</script>
