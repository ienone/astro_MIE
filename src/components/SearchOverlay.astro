---
import MaterialIconButton from "./material/IconButton.astro";
import MaterialTextField from "./material/TextField.astro";
import Ripple from "./material/Ripple.astro";
---

<dialog class="search-overlay" data-search-dialog aria-label="站内搜索" data-pagefind-ignore>
  <div class="search-panel">
    <form class="search-panel-head" method="dialog">
      <label for="site-search">搜索文章</label>
      <div class="search-panel-actions">
        <a class="search-page-link" href="/search/" data-search-page-link hidden><Ripple /><span>在搜索页中显示结果</span></a>
        <MaterialIconButton class="icon-button" icon="x" type="submit" data-search-close aria-label="关闭搜索" />
      </div>
    </form>
    <MaterialTextField id="site-search" class="search-field" data-search-input data-search-transition-source type="search" autocomplete="off" label="搜索文章" placeholder="搜索标题、标签或正文" />
    <div class="search-results" data-search-results></div>
  </div>
</dialog>

<script>
  // @ts-nocheck
  const htmlEntities = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" };
  let previousFocus;

  const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => htmlEntities[char] ?? char);
  const isSearchField = (element) => element instanceof HTMLElement && "value" in element;
  const getSearchValue = (element) => (isSearchField(element) && typeof element.value === "string" ? element.value : "");
  const setSearchValue = (element, value) => {
    if (isSearchField(element)) element.value = value;
  };

  async function ensurePagefind() {
    if (!window.__astroMiePagefind) {
      const pagefindPath = "/pagefind/pagefind.js";
      window.__astroMiePagefind = import(/* @vite-ignore */ pagefindPath);
    }

    return window.__astroMiePagefind;
  }

  function renderMessage(container, message) {
    if (!(container instanceof HTMLElement)) return;
    container.innerHTML = `<p class="search-empty">${escapeHtml(message)}</p>`;
  }

  function syncSearchPageLink(searchInput) {
    const link = document.querySelector("[data-search-page-link]");
    if (!isSearchField(searchInput) || !(link instanceof HTMLAnchorElement)) return;

    const query = getSearchValue(searchInput).trim();
    link.hidden = !query;
    link.href = query ? `/search/?q=${encodeURIComponent(query)}` : "/search/";
  }

  function attachDynamicRipples(container) {
    container.querySelectorAll("[data-mie-ripple]").forEach((element) => {
      if (element.querySelector("md-ripple")) return;
      element.prepend(document.createElement("md-ripple"));
    });
  }

  function renderResults(container, items) {
    if (!(container instanceof HTMLElement)) return;
    if (!items.length) {
      renderMessage(container, "没有找到匹配的文章。");
      return;
    }

    container.innerHTML = items
      .map(
        (item) => {
          const title = item.meta?.title || item.url;
          const excerpt = item.excerpt || escapeHtml(item.meta?.description || item.url);

          return `
          <a class="search-result" href="${escapeHtml(item.url)}" style="--result-index: ${item.index ?? 0}" data-mie-ripple>
            <span>${escapeHtml(title)}</span>
            <small>${excerpt}</small>
          </a>
        `;
        }
      )
      .join("");
    attachDynamicRipples(container);
  }

  function setupSearch(searchInput, searchResults, limit) {
    if (!isSearchField(searchInput) || !(searchResults instanceof HTMLElement)) return;
    if (searchInput.dataset.searchReady === "true") return;
    searchInput.dataset.searchReady = "true";

    let searchId = 0;

    searchInput.addEventListener("input", async (event) => {
      const target = event.currentTarget;
      if (!isSearchField(target)) return;

      const currentSearch = ++searchId;
      const query = getSearchValue(target).trim();
      syncSearchPageLink(searchInput);
      if (!query) {
        searchResults.innerHTML = "";
        return;
      }

      renderMessage(searchResults, "正在搜索…");

      try {
        const pagefindApi = await ensurePagefind();
        const search = await pagefindApi.search(query, { excerptLength: 30 });
        const items = await Promise.all(search.results.slice(0, limit).map(async (result, index) => ({ ...(await result.data()), index })));

        if (currentSearch === searchId) renderResults(searchResults, items);
      } catch (error) {
        window.__astroMiePagefind = undefined;
        if (currentSearch === searchId) renderMessage(searchResults, "搜索索引尚未生成，请先运行 npm run build。");
      }
    });
  }

  function openSearch() {
    const dialog = document.querySelector("[data-search-dialog]");
    const input = document.querySelector("[data-search-input]");
    const results = document.querySelector("[data-search-results]");
    if (!(dialog instanceof HTMLDialogElement)) return;
    previousFocus = document.activeElement;
    delete dialog.dataset.closing;
    if (!dialog.open) dialog.showModal();
    if (isSearchField(input)) {
      setSearchValue(input, "");
      syncSearchPageLink(input);
      window.setTimeout(() => input.focus(), 40);
    }
    if (results instanceof HTMLElement) results.innerHTML = "";
  }

  function closeSearch() {
    const dialog = document.querySelector("[data-search-dialog]");
    if (!(dialog instanceof HTMLDialogElement) || !dialog.open || dialog.dataset.closing === "true") return;

    dialog.dataset.closing = "true";
    window.setTimeout(() => {
      if (dialog.open) dialog.close();
      delete dialog.dataset.closing;
    }, 220);
  }

  function setupSearchOverlay() {
    const dialog = document.querySelector("[data-search-dialog]");
    const openers = document.querySelectorAll("[data-search-open]");
    const input = document.querySelector("[data-search-input]");
    const results = document.querySelector("[data-search-results]");
    const pageInput = document.querySelector("[data-search-page-input]");
    const pageResults = document.querySelector("[data-search-page-results]");

    setupSearch(input, results, 12);
    setupSearch(pageInput, pageResults, 30);

    if (isSearchField(pageInput) && pageInput.dataset.searchQueryLoaded !== "true") {
      const query = new URLSearchParams(window.location.search).get("q") || "";
      if (query) {
        pageInput.dataset.searchQueryLoaded = "true";
        setSearchValue(pageInput, query);
        pageInput.dispatchEvent(new Event("input", { bubbles: true }));
      }
    }

    openers.forEach((button) => {
      if (!(button instanceof HTMLElement) || button.dataset.searchOpenReady === "true") return;
      button.dataset.searchOpenReady = "true";
      button.addEventListener("click", openSearch);
    });

    if (dialog instanceof HTMLDialogElement && dialog.dataset.searchDialogReady !== "true") {
      dialog.dataset.searchDialogReady = "true";
      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) closeSearch();
      });
      dialog.addEventListener("cancel", (event) => {
        event.preventDefault();
        closeSearch();
      });
      dialog.addEventListener("close", () => {
        if (previousFocus instanceof HTMLElement) previousFocus.focus();
      });
      dialog.querySelector("form")?.addEventListener("submit", (event) => {
        event.preventDefault();
        closeSearch();
      });
    }
  }

  if (!window.__astroMieSearchBound) {
    window.__astroMieSearchBound = true;
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeSearch();
      if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        openSearch();
      }
    });
    document.addEventListener("astro:page-load", setupSearchOverlay);
  }

  setupSearchOverlay();
</script>
