---
import Icon from "./Icon.astro";
---

<div class="search-overlay" data-search-overlay hidden>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label="Site search">
    <div class="search-panel-head">
      <label for="site-search">Search posts</label>
      <button class="icon-button" type="button" data-search-close aria-label="Close search"><Icon name="x" /></button>
    </div>
    <input id="site-search" data-search-input type="search" autocomplete="off" placeholder="Search titles, tags, or body text" />
    <div class="search-results" data-search-results></div>
  </div>
</div>

<script is:inline>
  // @ts-nocheck
  const overlay = document.querySelector("[data-search-overlay]");
  const openers = document.querySelectorAll("[data-search-open]");
  const closer = document.querySelector("[data-search-close]");
  const input = document.querySelector("[data-search-input]");
  const results = document.querySelector("[data-search-results]");
  let index = [];
  const htmlEntities = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" };

  const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => htmlEntities[char] ?? char);

  async function ensureIndex() {
    if (index.length) return index;
    const response = await fetch("/search-index.json");
    index = await response.json();
    return index;
  }

  function render(items) {
    if (!(results instanceof HTMLElement)) return;
    if (!items.length) {
      results.innerHTML = '<p class="search-empty">No matching posts found.</p>';
      return;
    }

    results.innerHTML = items
      .slice(0, 12)
      .map(
        (item) => `
          <a class="search-result" href="${item.url}">
            <span>${escapeHtml(item.title)}</span>
            <small>${escapeHtml(item.description || "")}</small>
          </a>
        `
      )
      .join("");
  }

  async function search(value) {
    const query = value.trim().toLowerCase();
    if (!query) {
      render([]);
      return;
    }

    const data = await ensureIndex();
    render(
      data.filter((item) =>
        [item.title, item.description, item.tags.join(" "), item.categories.join(" "), item.series.join(" "), item.content]
          .join(" ")
          .toLowerCase()
          .includes(query)
      )
    );
  }

  function openSearch() {
    if (overlay instanceof HTMLElement) overlay.hidden = false;
    if (input instanceof HTMLInputElement) {
      input.value = "";
      input.focus();
    }
    render([]);
  }

  function closeSearch() {
    if (overlay instanceof HTMLElement) overlay.hidden = true;
  }

  openers.forEach((button) => button.addEventListener("click", openSearch));
  closer?.addEventListener("click", closeSearch);
  overlay?.addEventListener("click", (event) => {
    if (event.target === overlay) closeSearch();
  });
  input?.addEventListener("input", (event) => {
    if (event.target instanceof HTMLInputElement) search(event.target.value);
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeSearch();
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      openSearch();
    }
  });
</script>
