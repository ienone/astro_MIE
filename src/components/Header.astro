---
import Icon from "./Icon.astro";
import { isExternalLink, siteConfig } from "../lib/site";

function linkAttrs(href = "", explicitExternal = false, rel?: string) {
  const external = explicitExternal || isExternalLink(href);
  return {
    target: external ? "_blank" : undefined,
    rel: external ? rel || "noopener noreferrer" : rel
  };
}
---

<header class="site-header" data-site-header>
  <nav class="nav-shell" aria-label="Main navigation">
    <a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
      <img src={siteConfig.branding.logo} alt="" width="34" height="34" loading="eager" />
      <span>{siteConfig.name}</span>
    </a>

    <div class="nav-links" data-nav-links>
      {
        siteConfig.nav.map((item) =>
          Array.isArray(item.children) ? (
            <div class="nav-menu">
              <button class="nav-trigger" type="button" aria-haspopup="true">
                <Icon name={item.icon} />
                <span>{item.label}</span>
                <Icon name="chevron-down" />
              </button>
              <div class="nav-dropdown">
                {item.children.map((child) => (
                  <a class="nav-dropdown-link" href={child.href} {...linkAttrs(child.href, child.external, child.rel)}>
                    <Icon name={child.icon} />
                    <span>{child.label}</span>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a class="nav-link" href={item.href ?? "#"} {...linkAttrs(item.href, item.external, item.rel)}>
              <Icon name={item.icon} />
              <span>{item.label}</span>
            </a>
          )
        )
      }
    </div>

    <div class="nav-actions">
      <button class="icon-button" type="button" data-search-open aria-label="Open search"><Icon name="search" /></button>
      <button class="icon-button" type="button" data-theme-toggle aria-label="Toggle theme"><Icon name="sun-moon" /></button>
      <button class="menu-button" type="button" data-menu-toggle aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <Icon name="menu" />
      </button>
    </div>
  </nav>

  <div class="mobile-nav" id="mobile-nav" data-mobile-nav hidden>
    {
      siteConfig.nav.map((item) =>
        Array.isArray(item.children) ? (
          <details class="mobile-nav-group">
            <summary>
              <Icon name={item.icon} />
              <span>{item.label}</span>
            </summary>
            <div>
              {item.children.map((child) => (
                <a href={child.href} {...linkAttrs(child.href, child.external, child.rel)}>
                  <Icon name={child.icon} />
                  <span>{child.label}</span>
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a href={item.href ?? "#"} {...linkAttrs(item.href, item.external, item.rel)}>
            <Icon name={item.icon} />
            <span>{item.label}</span>
          </a>
        )
      )
    }
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-theme-toggle]");
  const menuButton = document.querySelector("[data-menu-toggle]");
  const mobileNav = document.querySelector("[data-mobile-nav]");

  toggle?.addEventListener("click", () => {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("theme", next);
  });

  menuButton?.addEventListener("click", () => {
    const isOpen = menuButton.getAttribute("aria-expanded") === "true";
    menuButton.setAttribute("aria-expanded", String(!isOpen));
    if (mobileNav instanceof HTMLElement) {
      mobileNav.hidden = isOpen;
    }
  });
</script>
