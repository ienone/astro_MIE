---
import Icon from "./Icon.astro";
import MaterialIconButton from "./material/IconButton.astro";
import Ripple from "./material/Ripple.astro";
import { isExternalLink, siteConfig } from "../lib/site";

const searchEnabled = siteConfig.features?.search !== false;
const highlightCurrentMenuArea = siteConfig.features?.highlightCurrentMenuArea !== false;
const homepage = siteConfig.homepage ?? {};
const primarySocial = siteConfig.author.links.find((link) => link.icon === "github") ?? siteConfig.author.links[0];

function getSocialText(link: { label: string; displayLabel?: string }) {
  return link.displayLabel || link.label;
}

function linkAttrs(href = "", explicitExternal = false, rel?: string) {
  const external = explicitExternal || isExternalLink(href);
  return {
    target: external ? "_blank" : undefined,
    rel: external ? rel || "noopener noreferrer" : rel
  };
}
---

<header class="site-header" data-site-header data-highlight-current-menu-area={String(highlightCurrentMenuArea)} transition:persist="site-header">
  <nav class="nav-shell" aria-label="Main navigation">
    <a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
      <img src={siteConfig.branding.logo} alt="" width="34" height="34" loading="eager" decoding="async" />
      <span>{siteConfig.name}</span>
    </a>

    <div class="nav-links" data-nav-links>
      {
        siteConfig.nav.map((item, index) =>
          Array.isArray(item.children) ? (
            <div class="nav-menu" data-nav-group>
              <button class="nav-trigger" type="button" aria-haspopup="true" aria-expanded="false" aria-controls={`nav-dropdown-${index}`} data-nav-trigger>
                <Ripple />
                <Icon name={item.icon} />
                <span>{item.label}</span>
                <Icon name="chevron-down" />
              </button>
              <div class="nav-dropdown" id={`nav-dropdown-${index}`} data-nav-dropdown>
                {item.children.map((child) => (
                  <a class="nav-dropdown-link" href={child.href} data-nav-href={child.href} {...linkAttrs(child.href, child.external, child.rel)}>
                    <Ripple />
                    <Icon name={child.icon} />
                    <span>{child.label}</span>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a class="nav-link" href={item.href ?? "#"} data-nav-href={item.href} {...linkAttrs(item.href, item.external, item.rel)}>
              <Ripple />
              <Icon name={item.icon} />
              <span>{item.label}</span>
            </a>
          )
        )
      }
    </div>

    <div class="nav-actions">
      {
        primarySocial && (
          <a
            class="nav-social-fusion-slot"
            data-home-fusion-social-slot
            data-pointer-light="control"
            href={primarySocial.href}
            aria-label={primarySocial.displayLabel ? `${primarySocial.label}: ${primarySocial.displayLabel}` : primarySocial.label}
            title={getSocialText(primarySocial)}
            tabindex="-1"
            aria-hidden="true"
            {...linkAttrs(primarySocial.href)}
          >
            <span class="nav-social-fusion-target" data-home-fusion-social-target>
              <Icon name={primarySocial.icon} />
            </span>
          </a>
        )
      }
      {searchEnabled && <MaterialIconButton class="icon-button" icon="search" data-search-open aria-label="Open search" />}
      <MaterialIconButton class="icon-button" icon="sun-moon" data-theme-toggle aria-label="Toggle theme" />
      <MaterialIconButton class="menu-button" icon="menu" data-menu-toggle aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav-overlay" />
    </div>
  </nav>
</header>

<div class="home-fusion-proxy-layer" data-home-fusion-proxy-layer aria-hidden="true">
  <div class="home-fusion-identity-proxy" data-home-fusion-identity-proxy>
    {siteConfig.branding.logo && <img class="home-fusion-proxy-avatar" src={siteConfig.branding.logo} alt="" width="56" height="56" decoding="async" />}
    <div class="home-fusion-proxy-copy">
      <p class="eyebrow">{homepage.eyebrow ?? "Personal static blog"}</p>
      <strong>{siteConfig.name}</strong>
      {siteConfig.author.headline && <span>{siteConfig.author.headline}</span>}
    </div>
  </div>
  {
    primarySocial && (
      <div class="home-fusion-social-proxy" data-home-fusion-social-proxy>
        <Icon name={primarySocial.icon} />
        <span class="home-fusion-social-proxy-label">{getSocialText(primarySocial)}</span>
      </div>
    )
  }
</div>

<div class="mobile-nav-overlay" id="mobile-nav-overlay" data-mobile-nav-overlay hidden>
  <section class="mobile-nav" data-mobile-nav role="dialog" aria-modal="true" aria-labelledby="mobile-nav-title" tabindex="-1">
    <div class="mobile-nav-head">
      <div>
        <p class="eyebrow">Navigation</p>
        <h2 id="mobile-nav-title">Site menu</h2>
      </div>
      <MaterialIconButton class="mobile-nav-close" icon="x" data-mobile-nav-close aria-label="Close menu" title="Close menu" />
    </div>

    <nav class="mobile-nav-list" aria-label="Mobile navigation">
      {
        siteConfig.nav.map((item) =>
          Array.isArray(item.children) ? (
            <details class="mobile-nav-group" data-mobile-nav-group>
              <summary class="mobile-nav-group-summary">
                <Ripple />
                <Icon name={item.icon} />
                <span>{item.label}</span>
                <span class="mobile-nav-chevron"><Icon name="chevron-down" /></span>
              </summary>
              <div class="mobile-nav-group-body">
                <div class="mobile-nav-sublist">
                  {item.children.map((child) => (
                    <a class="mobile-nav-subitem" href={child.href} data-nav-href={child.href} {...linkAttrs(child.href, child.external, child.rel)}>
                      <Ripple />
                      <Icon name={child.icon} />
                      <span>{child.label}</span>
                    </a>
                  ))}
                </div>
              </div>
            </details>
          ) : (
            <a class="mobile-nav-item" href={item.href ?? "#"} data-nav-href={item.href} {...linkAttrs(item.href, item.external, item.rel)}>
              <Ripple />
              <Icon name={item.icon} />
              <span>{item.label}</span>
              <span class="mobile-nav-current">Current</span>
            </a>
          )
        )
      }
    </nav>
  </section>
</div>

<script>
  const headerWindow = window as Window &
    typeof globalThis & {
      __astroMieHeaderBound?: boolean;
      __astroMieHeaderRaf?: number;
      __astroMieHeaderScrolled?: boolean;
      __astroMieNavCloseTimer?: number;
      __astroMieMobileNavCloseTimer?: number;
      __astroMieHomeFusionRaf?: number;
      __astroMieHomeFusionResizeTimer?: number;
      __astroMieHomeFusionFontReady?: boolean;
    };

  function normalizePath(path: string) {
    const normalized = path.replace(/\/+$/g, "");
    return normalized || "/";
  }

  function isSameArea(href: string, currentPath: string) {
    if (!href) return false;

    const url = new URL(href, window.location.origin);
    if (url.origin !== window.location.origin) return false;

    const targetPath = normalizePath(url.pathname);
    if (targetPath === "/") return currentPath === "/";

    return currentPath === targetPath || currentPath.startsWith(`${targetPath}/`);
  }

  function getNavTargetPath(href: string) {
    if (!href) return "";

    const url = new URL(href, window.location.origin);
    if (url.origin !== window.location.origin) return "";

    return normalizePath(url.pathname);
  }

  function getCurrentNavPath() {
    const currentSection = document.querySelector("[data-current-section]")?.getAttribute("data-current-section")?.trim();
    if (currentSection) return normalizePath(`/sections/${currentSection}/`);

    return normalizePath(window.location.pathname);
  }

  function moveNavIndicatorTo(target: Element | null, mode = "active") {
    const navLinks = document.querySelector("[data-nav-links]");
    if (!(navLinks instanceof HTMLElement)) return;

    if (!(target instanceof HTMLElement)) {
      navLinks.style.setProperty("--nav-indicator-opacity", "0");
      delete navLinks.dataset.indicatorMode;
      return;
    }

    const navRect = navLinks.getBoundingClientRect();
    const targetRect = target.getBoundingClientRect();
    navLinks.style.setProperty("--nav-indicator-x", `${targetRect.left - navRect.left}px`);
    navLinks.style.setProperty("--nav-indicator-y", `${targetRect.top - navRect.top}px`);
    navLinks.style.setProperty("--nav-indicator-width", `${targetRect.width}px`);
    navLinks.style.setProperty("--nav-indicator-height", `${targetRect.height}px`);
    navLinks.style.setProperty("--nav-indicator-opacity", "1");
    navLinks.dataset.indicatorMode = mode;
  }

  function updateNavIndicator() {
    const navLinks = document.querySelector("[data-nav-links]");
    if (!(navLinks instanceof HTMLElement)) return;

    const active = navLinks.querySelector('[aria-current="page"], [data-active="true"]');
    moveNavIndicatorTo(active instanceof HTMLElement ? active : null, "active");
  }

  function updateMobileNavGroups() {
    document.querySelectorAll("[data-mobile-nav-group]").forEach((group) => {
      const active = Boolean(group.querySelector('[aria-current="page"]'));
      if (active) {
        group.setAttribute("data-active", "true");
        if (group instanceof HTMLDetailsElement) group.open = true;
      } else {
        group.removeAttribute("data-active");
      }
    });
  }

  function updateActiveNav() {
    const highlightEnabled = document.querySelector("[data-site-header]")?.getAttribute("data-highlight-current-menu-area") !== "false";
    if (!highlightEnabled) {
      document.querySelectorAll("[data-nav-href]").forEach((link) => {
        if (!(link instanceof HTMLElement)) return;
        link.removeAttribute("aria-current");
      });
      document.querySelectorAll("[data-nav-trigger]").forEach((trigger) => {
        if (trigger instanceof HTMLElement) delete trigger.dataset.active;
      });
      const navLinks = document.querySelector("[data-nav-links]");
      if (navLinks instanceof HTMLElement) navLinks.style.setProperty("--nav-indicator-opacity", "0");
      updateMobileNavGroups();
      return;
    }

    const currentPath = getCurrentNavPath();
    const navHrefLinks = [...document.querySelectorAll("[data-nav-href]")];
    let activeTargetPath = "";
    let activeScore = -1;

    navHrefLinks.forEach((link) => {
      if (!(link instanceof HTMLElement)) return;
      const href = link.getAttribute("data-nav-href") || link.getAttribute("href") || "";
      const targetPath = getNavTargetPath(href);
      if (!targetPath || !isSameArea(href, currentPath)) return;

      const exactBonus = targetPath === currentPath ? 10000 : 0;
      const score = exactBonus + targetPath.length;
      if (score > activeScore) {
        activeTargetPath = targetPath;
        activeScore = score;
      }
    });

    navHrefLinks.forEach((link) => {
      if (!(link instanceof HTMLElement)) return;
      const href = link.getAttribute("data-nav-href") || link.getAttribute("href") || "";
      const active = activeTargetPath !== "" && getNavTargetPath(href) === activeTargetPath;
      link.toggleAttribute("aria-current", active);
      if (active) link.setAttribute("aria-current", "page");
    });

    document.querySelectorAll("[data-nav-group]").forEach((group) => {
      const trigger = group.querySelector("[data-nav-trigger]");
      const active = Boolean(group.querySelector('[aria-current="page"]'));
      if (trigger instanceof HTMLElement) {
        if (active) trigger.dataset.active = "true";
        else delete trigger.dataset.active;
      }
    });

    updateMobileNavGroups();
    updateNavIndicator();
  }

  function updateHeaderScrollState() {
    const scrolled = window.scrollY > 28;
    if (headerWindow.__astroMieHeaderScrolled === scrolled) return;

    headerWindow.__astroMieHeaderScrolled = scrolled;
    document.documentElement.dataset.scrolled = String(scrolled);
  }

  function clamp(value: number, min = 0, max = 1) {
    return Math.min(max, Math.max(min, value));
  }

  function lerp(start: number, end: number, progress: number) {
    return start + (end - start) * progress;
  }

  function ease(progress: number) {
    const t = clamp(progress);
    return t * t * (3 - 2 * t);
  }

  function easeOut(progress: number) {
    return 1 - Math.pow(1 - clamp(progress), 3);
  }

  function mapRange(value: number, inMin: number, inMax: number, outMin = 0, outMax = 1) {
    return lerp(outMin, outMax, clamp((value - inMin) / Math.max(1e-5, inMax - inMin)));
  }

  function getScrollPosition() {
    return window.scrollY || document.documentElement.scrollTop || 0;
  }

  function isHomePath() {
    return normalizePath(window.location.pathname) === "/";
  }

  function setElementStyles(element: HTMLElement, styles: Record<string, string>) {
    Object.entries(styles).forEach(([property, value]) => {
      element.style[property as any] = value;
    });
  }

  function clearElementStyles(element: HTMLElement | null | undefined, properties: string[]) {
    if (!(element instanceof HTMLElement)) return;
    properties.forEach((property) => element.style.removeProperty(property));
  }

  type FusionRect = {
    left: number;
    top: number;
    right: number;
    bottom: number;
    width: number;
    height: number;
  };

  function makeFusionRect(left: number, top: number, right: number, bottom: number): FusionRect {
    return {
      left,
      top,
      right,
      bottom,
      width: Math.max(0, right - left),
      height: Math.max(0, bottom - top)
    };
  }

  function rectFromDomRect(rect: DOMRect | DOMRectReadOnly): FusionRect {
    return makeFusionRect(rect.left, rect.top, rect.right, rect.bottom);
  }

  function inflateFusionRect(rect: FusionRect, inline = 0, block = 0) {
    return makeFusionRect(rect.left - inline, rect.top - block, rect.right + inline, rect.bottom + block);
  }

  function getContentRect(element: HTMLElement) {
    const childRects = Array.from(element.children)
      .filter((child): child is HTMLElement => child instanceof HTMLElement)
      .map((child) => rectFromDomRect(child.getBoundingClientRect()))
      .filter((rect) => rect.width > 0 && rect.height > 0);

    if (!childRects.length) return rectFromDomRect(element.getBoundingClientRect());

    return makeFusionRect(
      Math.min(...childRects.map((rect) => rect.left)),
      Math.min(...childRects.map((rect) => rect.top)),
      Math.max(...childRects.map((rect) => rect.right)),
      Math.max(...childRects.map((rect) => rect.bottom))
    );
  }

  function getHomeFusionElements() {
    const source = document.querySelector("[data-home-fusion-source]");
    const sourceIdentity = document.querySelector("[data-home-fusion-identity]");
    const sourceSocials = document.querySelector("[data-home-fusion-socials]");
    const sourcePrimarySocial = document.querySelector("[data-home-fusion-primary-social='true']");
    const identityProxy = document.querySelector("[data-home-fusion-identity-proxy]");
    const socialProxy = document.querySelector("[data-home-fusion-social-proxy]");
    const brand = document.querySelector(".brand");
    const socialSlot = document.querySelector("[data-home-fusion-social-slot]");
    const socialTarget = document.querySelector("[data-home-fusion-social-target]");

    if (
      !(source instanceof HTMLElement) ||
      !(sourceIdentity instanceof HTMLElement) ||
      !(identityProxy instanceof HTMLElement) ||
      !(brand instanceof HTMLElement)
    ) {
      return null;
    }

    return {
      source,
      sourceIdentity,
      sourceSocials: sourceSocials instanceof HTMLElement ? sourceSocials : undefined,
      sourcePrimarySocial: sourcePrimarySocial instanceof HTMLElement ? sourcePrimarySocial : undefined,
      secondarySocials: [...document.querySelectorAll<HTMLElement>("[data-home-fusion-socials] .social-link:not([data-home-fusion-primary-social='true'])")],
      identityProxy,
      socialProxy: socialProxy instanceof HTMLElement ? socialProxy : undefined,
      brand,
      brandAvatar: brand.querySelector("img") instanceof HTMLElement ? (brand.querySelector("img") as HTMLElement) : undefined,
      brandTitle: brand.querySelector("span") instanceof HTMLElement ? (brand.querySelector("span") as HTMLElement) : undefined,
      sourceAvatar: sourceIdentity.querySelector(".avatar") instanceof HTMLElement ? (sourceIdentity.querySelector(".avatar") as HTMLElement) : undefined,
      sourceTitle: sourceIdentity.querySelector("h1") instanceof HTMLElement ? (sourceIdentity.querySelector("h1") as HTMLElement) : undefined,
      socialSlot: socialSlot instanceof HTMLElement ? socialSlot : undefined,
      socialTarget: socialTarget instanceof HTMLElement ? socialTarget : undefined
    };
  }

  function getHomeFusionRange(source: HTMLElement) {
    const sourceRect = source.getBoundingClientRect();
    const scroll = getScrollPosition();
    const sourceTop = sourceRect.top + scroll;
    const header = document.querySelector("[data-site-header]");
    const headerHeight = header instanceof HTMLElement ? header.getBoundingClientRect().height : 72;
    const lead = clamp(window.innerHeight * 0.05, 32, 72);
    const duration = clamp(window.innerHeight * 0.3, 220, 360);
    const start = Math.max(0, sourceTop - headerHeight - lead);
    return { start, end: start + duration };
  }

  function measureHomeFusionGeometry(elements: NonNullable<ReturnType<typeof getHomeFusionElements>>) {
    const root = document.documentElement;
    const previousRootVars = {
      slotWidth: root.style.getPropertyValue("--home-social-slot-width"),
      brandSlotWidth: root.style.getPropertyValue("--home-brand-slot-width"),
      navGap: root.style.getPropertyValue("--home-nav-gap"),
      brandProgress: root.style.getPropertyValue("--home-brand-progress"),
      socialProgress: root.style.getPropertyValue("--home-social-target-progress")
    };
    const sourceIdentityInline = {
      opacity: elements.sourceIdentity.style.opacity,
      transform: elements.sourceIdentity.style.transform,
      filter: elements.sourceIdentity.style.filter
    };
    const sourcePrimaryInline = elements.sourcePrimarySocial
      ? {
          opacity: elements.sourcePrimarySocial.style.opacity,
          transform: elements.sourcePrimarySocial.style.transform,
          filter: elements.sourcePrimarySocial.style.filter
        }
      : undefined;
    const secondarySocialInline = elements.secondarySocials.map((element) => ({
      element,
      styles: {
        opacity: element.style.opacity,
        transform: element.style.transform,
        filter: element.style.filter
      }
    }));
    const brandInline = {
      opacity: elements.brand.style.opacity,
      transform: elements.brand.style.transform,
      width: elements.brand.style.width,
      maxWidth: elements.brand.style.maxWidth,
      overflow: elements.brand.style.overflow
    };

    root.style.setProperty("--home-brand-progress", "1");
    root.style.setProperty("--home-nav-gap", "18px");
    root.style.setProperty("--home-social-target-progress", "1");
    root.style.setProperty("--home-social-slot-width", "42px");
    setElementStyles(elements.sourceIdentity, { opacity: "1", transform: "none", filter: "none" });
    if (elements.sourcePrimarySocial) setElementStyles(elements.sourcePrimarySocial, { opacity: "1", transform: "none", filter: "none" });
    elements.secondarySocials.forEach((chip) => setElementStyles(chip, { opacity: "1", transform: "none", filter: "none" }));
    setElementStyles(elements.brand, { opacity: "1", transform: "none", width: "max-content", maxWidth: "none", overflow: "visible" });

    const sourceIdentityRect = inflateFusionRect(getContentRect(elements.sourceIdentity), 14, 10);
    const targetIdentityRect = elements.brand.getBoundingClientRect();
    const sourceSocialRect = elements.sourcePrimarySocial?.getBoundingClientRect();
    const targetSocialRect = elements.socialTarget?.getBoundingClientRect();
    const secondarySocialRects = elements.secondarySocials.map((chip) => rectFromDomRect(chip.getBoundingClientRect()));
    const sourceAvatarRect = elements.sourceAvatar?.getBoundingClientRect();
    const targetAvatarRect = elements.brandAvatar?.getBoundingClientRect();
    const sourceTitleRect = elements.sourceTitle?.getBoundingClientRect();
    const targetTitleRect = elements.brandTitle?.getBoundingClientRect();
    const sourceTitleStyles = elements.sourceTitle ? window.getComputedStyle(elements.sourceTitle) : undefined;
    const targetTitleStyles = elements.brandTitle ? window.getComputedStyle(elements.brandTitle) : undefined;
    const sourceTitleFontSize = parseFloat(sourceTitleStyles?.fontSize || "32") || 32;
    const targetTitleFontSize = parseFloat(targetTitleStyles?.fontSize || "16") || 16;
    const sourceTitleLineHeight =
      sourceTitleStyles?.lineHeight === "normal" ? sourceTitleFontSize * 1.08 : parseFloat(sourceTitleStyles?.lineHeight || "") || sourceTitleFontSize * 1.08;
    const targetTitleLineHeight =
      targetTitleStyles?.lineHeight === "normal" ? targetTitleFontSize * 1.08 : parseFloat(targetTitleStyles?.lineHeight || "") || targetTitleFontSize * 1.08;

    root.style.setProperty("--home-brand-progress", previousRootVars.brandProgress || "0");
    root.style.setProperty("--home-social-target-progress", previousRootVars.socialProgress || "0");
    if (previousRootVars.slotWidth) root.style.setProperty("--home-social-slot-width", previousRootVars.slotWidth);
    else root.style.removeProperty("--home-social-slot-width");
    if (previousRootVars.brandSlotWidth) root.style.setProperty("--home-brand-slot-width", previousRootVars.brandSlotWidth);
    else root.style.removeProperty("--home-brand-slot-width");
    if (previousRootVars.navGap) root.style.setProperty("--home-nav-gap", previousRootVars.navGap);
    else root.style.removeProperty("--home-nav-gap");
    setElementStyles(elements.sourceIdentity, sourceIdentityInline);
    if (elements.sourcePrimarySocial && sourcePrimaryInline) setElementStyles(elements.sourcePrimarySocial, sourcePrimaryInline);
    secondarySocialInline.forEach(({ element, styles }) => setElementStyles(element, styles));
    setElementStyles(elements.brand, brandInline);

    return {
      sourceIdentityRect,
      targetIdentityRect,
      sourceSocialRect,
      targetSocialRect,
      secondarySocialRects,
      sourceAvatarSize: sourceAvatarRect?.height || 56,
      targetAvatarSize: targetAvatarRect?.height || 34,
      sourceTitleWidth: sourceTitleRect?.width || Math.max(0, sourceIdentityRect.width - (sourceAvatarRect?.width || 56) - 14 - 28),
      targetTitleWidth: targetTitleRect?.width || Math.max(0, targetIdentityRect.width - (targetAvatarRect?.width || 34) - 10),
      sourceTitleFontSize,
      targetTitleFontSize,
      sourceTitleLineHeight,
      targetTitleLineHeight
    };
  }

  function measureFoldedBrandWidth() {
    const brand = document.querySelector(".brand");
    if (!(brand instanceof HTMLElement)) return 0;

    const previous = {
      opacity: brand.style.opacity,
      transform: brand.style.transform,
      width: brand.style.width,
      maxWidth: brand.style.maxWidth,
      overflow: brand.style.overflow
    };

    setElementStyles(brand, {
      opacity: "1",
      transform: "none",
      width: "max-content",
      maxWidth: "none",
      overflow: "visible"
    });

    const width = brand.getBoundingClientRect().width;
    setElementStyles(brand, previous);
    return Math.max(1, width);
  }

  let cachedHomeFusionGeometry: ReturnType<typeof measureHomeFusionGeometry> | undefined;
  let cachedHomeFusionRange: ReturnType<typeof getHomeFusionRange> | undefined;
  let cachedHomeFusionSource: HTMLElement | undefined;
  let cachedFoldedBrandWidth: number | undefined;

  function refreshHomeFusionMeasurements() {
    cachedFoldedBrandWidth = measureFoldedBrandWidth();

    if (!isHomePath()) {
      cachedHomeFusionGeometry = undefined;
      cachedHomeFusionRange = undefined;
      cachedHomeFusionSource = undefined;
      return;
    }

    const elements = getHomeFusionElements();
    if (!elements) {
      cachedHomeFusionGeometry = undefined;
      cachedHomeFusionRange = undefined;
      cachedHomeFusionSource = undefined;
      return;
    }

    cachedHomeFusionGeometry = measureHomeFusionGeometry(elements);
    cachedHomeFusionRange = getHomeFusionRange(elements.source);
    cachedHomeFusionSource = elements.source;
  }

  function getCachedHomeFusionLayout(elements: NonNullable<ReturnType<typeof getHomeFusionElements>>) {
    if (!cachedHomeFusionGeometry || !cachedHomeFusionRange || cachedHomeFusionSource !== elements.source) return null;
    return {
      geometry: cachedHomeFusionGeometry,
      range: cachedHomeFusionRange
    };
  }

  function refreshHomeFusionMeasurementsAndRender() {
    refreshHomeFusionMeasurements();
    renderHomeFusion();
  }

  function clearHomeFusionProxyStyles() {
    const identityProxy = document.querySelector("[data-home-fusion-identity-proxy]");
    const socialProxy = document.querySelector("[data-home-fusion-social-proxy]");
    clearElementStyles(identityProxy instanceof HTMLElement ? identityProxy : undefined, ["opacity", "width", "height", "transform", "border-radius", "pointer-events"]);
    clearElementStyles(socialProxy instanceof HTMLElement ? socialProxy : undefined, ["opacity", "width", "height", "transform", "border-radius", "pointer-events"]);
  }

  function setHomeFusionBrandInteractive(interactive: boolean) {
    const brand = document.querySelector(".brand");
    if (!(brand instanceof HTMLElement)) return;

    if (interactive) {
      brand.removeAttribute("tabindex");
      brand.removeAttribute("aria-hidden");
      brand.removeAttribute("inert");
      return;
    }

    brand.tabIndex = -1;
    brand.setAttribute("aria-hidden", "true");
    brand.setAttribute("inert", "");
  }

  function applyFoldedHomeFusionState() {
    const root = document.documentElement;
    const socialSlot = document.querySelector("[data-home-fusion-social-slot]");

    root.dataset.homeFusion = "true";
    root.dataset.homeFusionState = "folded";
    root.style.setProperty("--home-fusion-progress", "1");
    root.style.setProperty("--home-brand-progress", "1");
    if (cachedFoldedBrandWidth === undefined) cachedFoldedBrandWidth = measureFoldedBrandWidth();
    root.style.setProperty("--home-brand-slot-width", `${cachedFoldedBrandWidth}px`);
    root.style.setProperty("--home-nav-gap", "18px");
    root.style.setProperty("--home-social-target-progress", socialSlot instanceof HTMLElement ? "1" : "0");
    root.style.setProperty("--home-social-slot-width", socialSlot instanceof HTMLElement ? "42px" : "0px");
    clearHomeFusionProxyStyles();
    setHomeFusionBrandInteractive(true);

    if (socialSlot instanceof HTMLElement) {
      socialSlot.tabIndex = 0;
      socialSlot.setAttribute("aria-hidden", "false");
    }
  }

  function renderHomeFusion() {
    const root = document.documentElement;

    if (!isHomePath()) {
      applyFoldedHomeFusionState();
      return;
    }

    const elements = getHomeFusionElements();
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!elements) {
      clearHomeFusion();
      return;
    }

    const scroll = getScrollPosition();
    const layout = getCachedHomeFusionLayout(elements);
    if (!layout) return;

    const { start, end } = layout.range;
    const rawProgress = clamp((scroll - start) / Math.max(1, end - start));
    const progress = reduceMotion ? (rawProgress > 0.08 ? 1 : 0) : rawProgress;
    const state = progress <= 0.01 ? "expanded" : progress >= 0.92 ? "folded" : "merging";
    const { geometry } = layout;

    root.dataset.homeFusion = "true";
    root.dataset.homeFusionState = state;
    root.style.setProperty("--home-fusion-progress", progress.toFixed(4));
    setHomeFusionBrandInteractive(state === "folded");

    const sourceSurfaceAlpha = 1 - easeOut(mapRange(progress, 0.005, 0.10));
    const identityProxyIn = ease(mapRange(progress, 0.005, 0.045));
    const identityMove = ease(mapRange(progress, 0.05, 0.66));
    const identityContent = identityMove;
    const identitySourceFade = identityProxyIn;
    const identityTarget = ease(mapRange(progress, 0.72, 0.90));
    const identityExtra = identityContent;
    const socialProxyIn = ease(mapRange(progress, 0.04, 0.10));
    const socialSourceFade = ease(mapRange(progress, 0.02, 0.12));
    const socialMove = ease(mapRange(progress, 0.12, 0.68));
    const brandSlot = easeOut(mapRange(progress, 0.36, 0.82));
    const socialSlot = easeOut(mapRange(progress, 0.34, 0.78));
    const socialTarget = ease(mapRange(progress, 0.68, 0.90));
    const navExpand = Math.max(brandSlot, socialSlot);

    elements.source.style.setProperty("--home-fusion-source-surface-alpha", `${(sourceSurfaceAlpha * 100).toFixed(2)}%`);
    root.style.setProperty("--home-nav-gap", `${lerp(10, 18, navExpand)}px`);
    root.style.setProperty("--home-brand-progress", identityTarget.toFixed(4));
    root.style.setProperty("--home-brand-slot-width", `${lerp(0, geometry.targetIdentityRect.width, brandSlot)}px`);
    root.style.setProperty("--home-social-target-progress", socialTarget.toFixed(4));
    root.style.setProperty("--home-social-slot-width", `${lerp(0, 42, socialSlot)}px`);

    setElementStyles(elements.sourceIdentity, {
      opacity: (1 - identitySourceFade).toFixed(4),
      transform: "none",
      filter: "none",
      visibility: identitySourceFade > 0.98 ? "hidden" : "",
      pointerEvents: progress > 0.08 ? "none" : ""
    });

    if (elements.sourceSocials) {
      setElementStyles(elements.sourceSocials, {
        opacity: (1 - socialSourceFade).toFixed(4),
        transform: "none",
        filter: "none",
        visibility: socialSourceFade > 0.98 ? "hidden" : "",
        pointerEvents: socialSourceFade > 0.45 ? "none" : ""
      });
    }

    elements.secondarySocials.forEach((chip, index) => {
      const chipRect = geometry.secondarySocialRects[index];
      const stackTarget = geometry.sourceSocialRect;
      const itemProgress = easeOut(mapRange(progress, 0.03 + index * 0.018, 0.22 + index * 0.026));
      const stackX =
        chipRect && stackTarget ? stackTarget.left + stackTarget.width / 2 - (chipRect.left + chipRect.width / 2) : 0;
      const stackY =
        chipRect && stackTarget ? stackTarget.top + stackTarget.height / 2 - (chipRect.top + chipRect.height / 2) : -14;
      const stackOffsetY = stackTarget ? (index % 2 === 0 ? -1 : 1) * Math.min(3, index + 1) : 0;
      setElementStyles(chip, {
        opacity: (1 - itemProgress).toFixed(4),
        transform: `translate3d(${lerp(0, stackX, itemProgress)}px, ${lerp(0, stackY + stackOffsetY, itemProgress)}px, 0) scale(${lerp(1, 0.74, itemProgress)})`,
        filter: `blur(${lerp(0, 6, itemProgress)}px)`,
        pointerEvents: itemProgress > 0.45 ? "none" : ""
      });
    });

    if (elements.sourcePrimarySocial) {
      setElementStyles(elements.sourcePrimarySocial, {
        opacity: (1 - socialSourceFade).toFixed(4),
        transform: "none",
        filter: "none",
        visibility: socialSourceFade > 0.98 ? "hidden" : "",
        pointerEvents: progress > 0.16 ? "none" : ""
      });
    }

    const identityX = lerp(geometry.sourceIdentityRect.left, geometry.targetIdentityRect.left, identityMove);
    const identityY = lerp(geometry.sourceIdentityRect.top, geometry.targetIdentityRect.top, identityMove);
    const identityPaddingInline = lerp(14, 0, identityContent);
    const identityPaddingBlock = lerp(10, 0, identityContent);
    const identityAvatarSize = lerp(geometry.sourceAvatarSize, geometry.targetAvatarSize, identityContent);
    const identityGap = lerp(14, 10, identityContent);
    const identityTitleWidth = lerp(geometry.sourceTitleWidth, geometry.targetTitleWidth, identityContent);
    const identityContentWidth = identityAvatarSize + identityGap + identityTitleWidth + identityPaddingInline * 2;
    const identityProxyOut = ease(mapRange(progress, 0.72, 0.92));
    const identityWidthSafety = lerp(10, 6, identityContent) * (1 - identityProxyOut);
    const identityWidth = Math.max(
      lerp(geometry.sourceIdentityRect.width, geometry.targetIdentityRect.width, identityMove),
      identityContentWidth + identityWidthSafety
    );
    const identityHeight = Math.max(
      lerp(geometry.sourceIdentityRect.height, geometry.targetIdentityRect.height, identityMove),
      identityAvatarSize + identityPaddingBlock * 2
    );
    setElementStyles(elements.identityProxy, {
      opacity: progress > 0.015 && progress < 0.96 ? (identityProxyIn * (1 - identityProxyOut)).toFixed(4) : "0",
      width: `${Math.max(1, identityWidth)}px`,
      height: `${Math.max(1, identityHeight)}px`,
      transform: `translate3d(${identityX}px, ${identityY}px, 0)`,
      borderRadius: `${lerp(28, 999, identityMove)}px`,
      pointerEvents: "none"
    });
    elements.identityProxy.style.setProperty("--fusion-proxy-avatar-size", `${identityAvatarSize}px`);
    elements.identityProxy.style.setProperty("--fusion-proxy-title-size", `${lerp(geometry.sourceTitleFontSize, geometry.targetTitleFontSize, identityContent)}px`);
    elements.identityProxy.style.setProperty("--fusion-proxy-title-weight", `${lerp(850, 800, identityContent)}`);
    elements.identityProxy.style.setProperty("--fusion-proxy-title-line-height", `${lerp(geometry.sourceTitleLineHeight, geometry.targetTitleLineHeight, identityContent)}px`);
    elements.identityProxy.style.setProperty("--fusion-proxy-gap", `${identityGap}px`);
    elements.identityProxy.style.setProperty("--fusion-proxy-padding-block", `${identityPaddingBlock}px`);
    elements.identityProxy.style.setProperty("--fusion-proxy-padding-inline", `${identityPaddingInline}px`);
    elements.identityProxy.style.setProperty("--fusion-proxy-extra-opacity", `${1 - identityExtra}`);
    elements.identityProxy.style.setProperty("--fusion-proxy-surface-alpha", `${(70 * (1 - identityMove)).toFixed(2)}%`);
    elements.identityProxy.style.setProperty("--fusion-proxy-border-alpha", `${(48 * (1 - identityMove)).toFixed(2)}%`);

    if (elements.socialProxy && geometry.sourceSocialRect && geometry.targetSocialRect) {
      const socialX = lerp(geometry.sourceSocialRect.left, geometry.targetSocialRect.left, socialMove);
      const socialY = lerp(geometry.sourceSocialRect.top, geometry.targetSocialRect.top, socialMove);
      const socialWidth = lerp(geometry.sourceSocialRect.width, geometry.targetSocialRect.width, socialMove);
      const socialHeight = lerp(geometry.sourceSocialRect.height, geometry.targetSocialRect.height, socialMove);
      const socialProxyOut = ease(mapRange(progress, 0.72, 0.92));
      setElementStyles(elements.socialProxy, {
        opacity: progress > 0.035 && progress < 0.96 ? (socialProxyIn * (1 - socialProxyOut)).toFixed(4) : "0",
        width: `${Math.max(1, socialWidth)}px`,
        height: `${Math.max(1, socialHeight)}px`,
        transform: `translate3d(${socialX}px, ${socialY}px, 0)`,
        borderRadius: "999px",
        pointerEvents: "none"
      });
      elements.socialProxy.style.setProperty("--fusion-social-icon-size", `${lerp(20, 20, socialMove)}px`);
      elements.socialProxy.style.setProperty("--fusion-social-padding-inline", "0px");
      elements.socialProxy.style.setProperty("--fusion-social-surface-alpha", `${(58 * (1 - socialMove)).toFixed(2)}%`);
      elements.socialProxy.style.setProperty("--fusion-social-border-alpha", `${(56 * (1 - socialMove)).toFixed(2)}%`);
    } else if (elements.socialProxy) {
      elements.socialProxy.style.opacity = "0";
    }

    if (elements.socialSlot) {
      elements.socialSlot.tabIndex = progress >= 0.92 ? 0 : -1;
      elements.socialSlot.setAttribute("aria-hidden", progress >= 0.92 ? "false" : "true");
    }
  }

  function clearHomeFusion() {
    const root = document.documentElement;
    delete root.dataset.homeFusion;
    delete root.dataset.homeFusionState;
    root.style.removeProperty("--home-fusion-progress");
    root.style.removeProperty("--home-brand-progress");
    root.style.removeProperty("--home-brand-slot-width");
    root.style.removeProperty("--home-nav-gap");
    root.style.removeProperty("--home-social-target-progress");
    root.style.removeProperty("--home-social-slot-width");

    const socialSlot = document.querySelector("[data-home-fusion-social-slot]");
    const source = document.querySelector("[data-home-fusion-source]");
    clearHomeFusionProxyStyles();
    setHomeFusionBrandInteractive(true);
    if (source instanceof HTMLElement) source.style.removeProperty("--home-fusion-source-surface-alpha");
    if (socialSlot instanceof HTMLElement) {
      socialSlot.tabIndex = -1;
      socialSlot.setAttribute("aria-hidden", "true");
    }

    const elements = getHomeFusionElements();
    if (!elements) return;
    clearElementStyles(elements.sourceIdentity, ["opacity", "transform", "filter", "visibility", "pointer-events"]);
    clearElementStyles(elements.sourceSocials, ["opacity", "transform", "filter", "visibility", "pointer-events"]);
    clearElementStyles(elements.sourcePrimarySocial, ["opacity", "transform", "filter", "visibility", "pointer-events"]);
    elements.secondarySocials.forEach((chip) => clearElementStyles(chip, ["opacity", "transform", "filter", "visibility", "pointer-events"]));
  }

  function scheduleHomeFusionRender() {
    if (headerWindow.__astroMieHomeFusionRaf) return;
    headerWindow.__astroMieHomeFusionRaf = window.requestAnimationFrame(() => {
      headerWindow.__astroMieHomeFusionRaf = undefined;
      renderHomeFusion();
    });
  }

  function closeNavMenus(except?: Element, restoreIndicator = true) {
    if (headerWindow.__astroMieNavCloseTimer) {
      window.clearTimeout(headerWindow.__astroMieNavCloseTimer);
      headerWindow.__astroMieNavCloseTimer = undefined;
    }

    let closed = false;

    document.querySelectorAll("[data-nav-group]").forEach((group) => {
      if (except && group === except) return;
      if (!(group instanceof HTMLElement)) return;
      if (group.dataset.open === "true") closed = true;

      delete group.dataset.open;
      const trigger = group.querySelector("[data-nav-trigger]");
      if (trigger instanceof HTMLElement) trigger.setAttribute("aria-expanded", "false");
    });

    if (closed && !except && restoreIndicator) updateNavIndicator();
  }

  function scheduleCloseNavMenus() {
    if (headerWindow.__astroMieNavCloseTimer) window.clearTimeout(headerWindow.__astroMieNavCloseTimer);
    headerWindow.__astroMieNavCloseTimer = window.setTimeout(() => {
      closeNavMenus();
    }, 140);
  }

  function toggleNavGroup(trigger: HTMLElement) {
    const group = trigger.closest("[data-nav-group]");
    if (!(group instanceof HTMLElement)) return;

    const shouldOpen = group.dataset.open !== "true";
    closeNavMenus(shouldOpen ? group : undefined);

    if (shouldOpen) {
      openNavGroup(trigger);
    } else {
      delete group.dataset.open;
      trigger.setAttribute("aria-expanded", "false");
      updateNavIndicator();
    }
  }

  function openNavGroup(trigger: HTMLElement) {
    const group = trigger.closest("[data-nav-group]");
    if (!(group instanceof HTMLElement)) return;

    if (headerWindow.__astroMieNavCloseTimer) {
      window.clearTimeout(headerWindow.__astroMieNavCloseTimer);
      headerWindow.__astroMieNavCloseTimer = undefined;
    }

    closeNavMenus(group);
    group.dataset.open = "true";
    trigger.setAttribute("aria-expanded", "true");
    moveNavIndicatorTo(trigger, "open");
  }

  function markDropdownPress(link: HTMLElement) {
    link.dataset.pressed = "true";
    window.setTimeout(() => delete link.dataset.pressed, 220);
  }

  async function toggleThemeFrom(button: HTMLElement) {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    const applyTheme = () => {
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
    };

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!document.startViewTransition || reduceMotion) {
      applyTheme();
      return;
    }

    const rect = button.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;
    const endRadius = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));

    document.documentElement.classList.add("theme-transitioning");
    const transition = document.startViewTransition(applyTheme);

    try {
      await transition.ready;
      document.documentElement.animate(
        {
          clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${endRadius}px at ${x}px ${y}px)`]
        },
        {
          duration: 520,
          easing: "cubic-bezier(0.2, 0, 0, 1)",
          pseudoElement: "::view-transition-new(root)"
        }
      );
      await transition.finished;
    } finally {
      document.documentElement.classList.remove("theme-transitioning");
    }
  }

  function setMobileMenu(open: boolean, restoreFocus = true) {
    const menuButton = document.querySelector("[data-menu-toggle]");
    const overlay = document.querySelector("[data-mobile-nav-overlay]");
    const mobileNav = document.querySelector("[data-mobile-nav]");
    if (!(menuButton instanceof HTMLElement) || !(overlay instanceof HTMLElement) || !(mobileNav instanceof HTMLElement)) return;

    if (headerWindow.__astroMieMobileNavCloseTimer) {
      window.clearTimeout(headerWindow.__astroMieMobileNavCloseTimer);
      headerWindow.__astroMieMobileNavCloseTimer = undefined;
    }

    menuButton.setAttribute("aria-expanded", String(open));
    if (open) {
      updateMobileNavGroups();
      overlay.hidden = false;
      document.documentElement.dataset.mobileNavOpen = "true";
      window.requestAnimationFrame(() => {
        overlay.dataset.open = "true";
        mobileNav.focus({ preventScroll: true });
      });
      return;
    }

    overlay.dataset.open = "false";
    delete document.documentElement.dataset.mobileNavOpen;
    headerWindow.__astroMieMobileNavCloseTimer = window.setTimeout(() => {
      if (menuButton.getAttribute("aria-expanded") === "false") overlay.hidden = true;
      if (restoreFocus) menuButton.focus({ preventScroll: true });
    }, 260);
  }

  function isMobileMenuOpen() {
    return document.documentElement.dataset.mobileNavOpen === "true";
  }

  function trapMobileNavFocus(event: KeyboardEvent) {
    const mobileNav = document.querySelector("[data-mobile-nav]");
    if (!(mobileNav instanceof HTMLElement)) return;

    const focusable = [
      ...mobileNav.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), summary, md-filled-tonal-icon-button, [tabindex]:not([tabindex="-1"])'
      )
    ].filter((item) => !item.hasAttribute("disabled") && item.offsetParent !== null);

    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (!first || !last) return;

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  }

  function setupNavIndicatorPreview(header: Element) {
    const navLinks = header.querySelector("[data-nav-links]");
    if (navLinks instanceof HTMLElement && navLinks.dataset.navIndicatorHostReady !== "true") {
      navLinks.dataset.navIndicatorHostReady = "true";
      navLinks.addEventListener("pointerleave", updateNavIndicator);
      navLinks.addEventListener("focusout", (event) => {
        const next = event.relatedTarget instanceof Node ? event.relatedTarget : null;
        if (!next || !navLinks.contains(next)) updateNavIndicator();
      });
    }

    header.querySelectorAll(".nav-link, [data-nav-trigger]").forEach((item) => {
      if (!(item instanceof HTMLElement) || item.dataset.navIndicatorReady === "true") return;
      item.dataset.navIndicatorReady = "true";
      const indicatorMode = item.matches("[data-nav-trigger]") ? "open" : "preview";
      item.addEventListener("pointerenter", () => {
        closeNavMenus(item.closest("[data-nav-group]") ?? undefined, false);
        moveNavIndicatorTo(item, indicatorMode);
      });
      item.addEventListener("focusin", () => {
        closeNavMenus(item.closest("[data-nav-group]") ?? undefined, false);
        moveNavIndicatorTo(item, indicatorMode);
      });
    });
  }

  function setupMobileNav() {
    const overlay = document.querySelector("[data-mobile-nav-overlay]");
    if (!(overlay instanceof HTMLElement) || overlay.dataset.mobileNavReady === "true") return;

    overlay.dataset.mobileNavReady = "true";
    overlay.addEventListener("click", (event) => {
      const target = event.target instanceof Element ? event.target : null;
      if (target === overlay || target?.closest("[data-mobile-nav-close]")) {
        setMobileMenu(false);
        return;
      }

      if (target?.closest(".mobile-nav-item, .mobile-nav-subitem")) setMobileMenu(false, false);
    });
  }

  function setupNavGroups(header: Element) {
    header.querySelectorAll("[data-nav-group]").forEach((group) => {
      if (!(group instanceof HTMLElement) || group.dataset.navGroupReady === "true") return;
      const trigger = group.querySelector("[data-nav-trigger]");
      if (!(trigger instanceof HTMLElement)) return;

      group.dataset.navGroupReady = "true";
      group.addEventListener("pointerenter", () => openNavGroup(trigger));
      group.addEventListener("pointerleave", scheduleCloseNavMenus);
      group.addEventListener("focusin", () => openNavGroup(trigger));
      group.addEventListener("focusout", (event) => {
        const next = event.relatedTarget instanceof Node ? event.relatedTarget : null;
        if (!next || !group.contains(next)) scheduleCloseNavMenus();
      });
    });
  }

  function setupHeader() {
    const header = document.querySelector("[data-site-header]");
    const toggles = document.querySelectorAll("[data-theme-toggle]");
    const menuButton = document.querySelector("[data-menu-toggle]");

    if (header instanceof HTMLElement && header.dataset.headerReady !== "true") {
      header.dataset.headerReady = "true";
      setupNavIndicatorPreview(header);

      header.querySelectorAll("[data-nav-trigger]").forEach((trigger) => {
        if (!(trigger instanceof HTMLElement)) return;
        trigger.addEventListener("click", (event) => {
          event.stopPropagation();
          toggleNavGroup(trigger);
        });
      });

      header.querySelectorAll(".nav-dropdown-link").forEach((link) => {
        if (!(link instanceof HTMLElement)) return;
        link.addEventListener("pointerdown", () => markDropdownPress(link));
        link.addEventListener("click", () => closeNavMenus());
      });

      menuButton?.addEventListener("click", () => {
        const isOpen = menuButton.getAttribute("aria-expanded") === "true";
        setMobileMenu(!isOpen);
      });
    }

    if (header instanceof HTMLElement) setupNavIndicatorPreview(header);
    if (header instanceof HTMLElement) setupNavGroups(header);
    setupMobileNav();

    toggles.forEach((toggle) => {
      if (!(toggle instanceof HTMLElement) || toggle.dataset.themeToggleReady === "true") return;
      toggle.dataset.themeToggleReady = "true";
      toggle.addEventListener("click", () => {
        if (toggle instanceof HTMLElement) toggleThemeFrom(toggle);
      });
    });

    updateHeaderScrollState();
    refreshHomeFusionMeasurementsAndRender();
    updateActiveNav();
  }

  if (!headerWindow.__astroMieHeaderBound) {
    headerWindow.__astroMieHeaderBound = true;

    window.addEventListener(
      "scroll",
      () => {
        if (headerWindow.__astroMieHeaderRaf) window.cancelAnimationFrame(headerWindow.__astroMieHeaderRaf);
        headerWindow.__astroMieHeaderRaf = window.requestAnimationFrame(() => {
          updateHeaderScrollState();
          scheduleHomeFusionRender();
        });
      },
      { passive: true }
    );
    window.addEventListener("resize", () => {
      updateNavIndicator();
      window.clearTimeout(headerWindow.__astroMieHomeFusionResizeTimer);
      headerWindow.__astroMieHomeFusionResizeTimer = window.setTimeout(refreshHomeFusionMeasurementsAndRender, 80);
    });
    if (!headerWindow.__astroMieHomeFusionFontReady && "fonts" in document) {
      headerWindow.__astroMieHomeFusionFontReady = true;
      document.fonts?.ready.then(refreshHomeFusionMeasurementsAndRender);
    }
    document.addEventListener("click", (event) => {
      const target = event.target instanceof Element ? event.target : null;
      if (target?.closest("[data-nav-group]")) return;
      closeNavMenus();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Tab" && isMobileMenuOpen()) {
        trapMobileNavFocus(event);
        return;
      }

      if (event.key !== "Escape") return;
      if (isMobileMenuOpen()) {
        setMobileMenu(false);
        return;
      }

      closeNavMenus();
    });
    document.addEventListener("astro:page-load", setupHeader);
  }

  setupHeader();
</script>
