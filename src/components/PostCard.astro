---
import type { PostEntry } from "../lib/posts";
import {
  formatDate,
  getPostImage,
  getPostImagePosition,
  getPostTransitionName,
  getPostUrl,
  readingTime,
  wordCount,
  getSectionLabel
} from "../lib/posts";

interface Props {
  post: PostEntry;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const image = getPostImage(post);
const url = getPostUrl(post);
const stats = `${wordCount(post.body).toLocaleString("en-US")} words · ${readingTime(post.body)}`;
const style = { "--post-theme": post.data.themeColor };
const imagePosition = getPostImagePosition(post);
const coverTransitionName = getPostTransitionName(post, "cover");
const titleTransitionName = getPostTransitionName(post, "title");
---

<article class:list={["post-card", { compact }]} style={style}>
  <a href={url} class="post-card-link" aria-label={`Read ${post.data.title}`}>
    <div class="post-card-media">
      <img
        src={image}
        alt={post.data.media?.alt || post.data.title}
        loading="lazy"
        style={{ objectPosition: imagePosition }}
        transition:name={coverTransitionName}
      />
    </div>
    <div class="post-card-body">
      <div class="eyebrow">{getSectionLabel(post.data.section)} · {formatDate(post.data.date)}</div>
      <h2 transition:name={titleTransitionName}>{post.data.title}</h2>
      {post.data.description && <p>{post.data.description}</p>}
      <div class="meta-row">
        <span>{stats}</span>
        {post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </a>
</article>
