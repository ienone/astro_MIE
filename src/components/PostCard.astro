---
import type { PostEntry } from "../lib/posts";
import OptimizedImage from "./OptimizedImage.astro";
import {
  formatDate,
  getPostImage,
  getPostImagePosition,
  getPostThemeColor,
  getPostTransitionSetName,
  getPostTransitionName,
  getPostUrl,
  readingTime,
  wordCount,
  getSectionLabel
} from "../lib/posts";

interface Props {
  post: PostEntry;
  compact?: boolean;
  showSummary?: boolean;
  showMeta?: boolean;
}

const { post, compact = false, showSummary = true, showMeta = true } = Astro.props;
const image = getPostImage(post);
const url = getPostUrl(post);
const stats = `${wordCount(post.body).toLocaleString("en-US")} words · ${readingTime(post.body)}`;
const style = { "--post-theme": getPostThemeColor(post) };
const imagePosition = getPostImagePosition(post);
const transitionSetName = getPostTransitionSetName(post);
const coverTransitionName = getPostTransitionName(post, "cover");
const titleTransitionName = getPostTransitionName(post, "title");
---

<article
  class:list={["post-card", { compact }]}
  style={style}
  data-post-card
  data-post-transition-cover={coverTransitionName}
  data-post-transition-title={titleTransitionName}
  data-route-shared-set={transitionSetName}
  data-route-shared-context="card"
  data-route-shared-target-context="article"
>
  <a href={url} class="post-card-link" aria-label={`Read ${post.data.title}`}>
    <div class="post-card-media">
      <div
        class="post-cover-transition"
        data-post-transition-cover={coverTransitionName}
        data-route-shared
        data-route-shared-set={transitionSetName}
        data-route-shared-name={coverTransitionName}
        data-route-shared-group="post-cover"
        data-route-shared-context="card"
        data-route-shared-target-context="article"
        data-route-shared-exit="fade"
        data-route-shared-suppress-visual="true"
        transition:name={coverTransitionName}
      >
        <OptimizedImage
          src={image}
          alt={post.data.media?.alt || post.data.title}
          loading="lazy"
          decoding="async"
          widths={[360, 540, 720, 960]}
          sizes={compact ? "(min-width: 900px) 33vw, 50vw" : "(min-width: 900px) 360px, 100vw"}
          fit="cover"
          position={imagePosition}
          style={{ objectPosition: imagePosition }}
        />
      </div>
    </div>
    <div class="post-card-body">
      <div class="eyebrow">{getSectionLabel(post.data.section)} · {formatDate(post.data.date)}</div>
      <h2
        class="post-title-transition"
        data-post-transition-title={titleTransitionName}
        data-route-shared
        data-route-shared-set={transitionSetName}
        data-route-shared-name={titleTransitionName}
        data-route-shared-group="post-title"
        data-route-shared-context="card"
        data-route-shared-target-context="article"
        data-route-shared-exit="fade"
        data-route-shared-suppress-visual="true"
        transition:name={titleTransitionName}
      >
        {post.data.title}
      </h2>
      {showSummary && post.data.description && <p>{post.data.description}</p>}
      {showMeta && (
        <div class="meta-row">
          <span>{stats}</span>
          {post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
        </div>
      )}
    </div>
  </a>
</article>
