---
import Icon from "./Icon.astro";
import { isExternalLink, siteConfig } from "../lib/site";

const defaultFooterLinks = [
  { label: "RSS", href: "/rss.xml", icon: "rss" }
];
const footerConfig = siteConfig.footer ?? {};
const showMenu = footerConfig.showMenu !== false;
const showCopyright = footerConfig.showCopyright !== false;
const showThemeAttribution = footerConfig.showThemeAttribution !== false;
const showAppearanceSwitcher = footerConfig.showAppearanceSwitcher !== false;
const showScrollToTop = footerConfig.showScrollToTop !== false;
const seenFooterHrefs = new Set<string>();
const footerLinks = [...defaultFooterLinks, ...(footerConfig.links ?? [])].filter((link) => {
  if (seenFooterHrefs.has(link.href)) return false;
  seenFooterHrefs.add(link.href);
  return true;
});
const footerActionHrefs = new Set(footerLinks.map((link) => link.href));
const footerSocialLinks = siteConfig.author.links.filter((link) => !footerActionHrefs.has(link.href));
const showFooterSocial = Astro.url.pathname !== "/";

function getSocialText(link: { label: string; displayLabel?: string }) {
  return link.displayLabel || link.label;
}
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <p class="footer-title">{siteConfig.name}</p>
      <p>{siteConfig.description}</p>
    </div>
    <div class="footer-links">
      {showMenu && <div class="footer-actions" aria-label="Footer links">
        {
          footerLinks.map((link) => (
            <a href={link.href} target={isExternalLink(link.href) ? "_blank" : undefined} rel={isExternalLink(link.href) ? "noopener noreferrer" : undefined}>
              <Icon name={link.icon} />
              <span>{link.label}</span>
            </a>
          ))
        }
      </div>}
      {
        showMenu && showFooterSocial && footerSocialLinks.length > 0 && (
          <div class="footer-social social-links" aria-label="社交平台">
            {footerSocialLinks.map((link) => (
              <a
                class="social-link"
                href={link.href}
                target={isExternalLink(link.href) ? "_blank" : undefined}
                rel={isExternalLink(link.href) ? "noopener noreferrer" : undefined}
                aria-label={link.displayLabel ? `${link.label}: ${link.displayLabel}` : link.label}
                title={getSocialText(link)}
              >
                <Icon name={link.icon} />
                <span class="social-link__label">{getSocialText(link)}</span>
              </a>
            ))}
          </div>
        )
      }
      {(showAppearanceSwitcher || showScrollToTop) && (
        <div class="footer-actions footer-controls" aria-label="Footer controls">
          {showAppearanceSwitcher && <button type="button" data-theme-toggle><Icon name="sun-moon" /><span>Theme</span></button>}
          {showScrollToTop && <button type="button" data-scroll-top><Icon name="chevron-down" /><span>Top</span></button>}
        </div>
      )}
      {(showCopyright || showThemeAttribution) && (
        <div class="footer-meta">
          {showCopyright && <p>© {new Date().getFullYear()} {siteConfig.author.displayName || siteConfig.author.name}</p>}
          {showThemeAttribution && <p>Powered by Astro MIE.</p>}
        </div>
      )}
    </div>
  </div>
</footer>

<script>
  function setupFooterControls() {
    document.querySelectorAll("[data-scroll-top]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement) || button.dataset.scrollTopReady === "true") return;
      button.dataset.scrollTopReady = "true";
      button.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
    });
  }

  document.addEventListener("astro:page-load", setupFooterControls);
  setupFooterControls();
</script>
