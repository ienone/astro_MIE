---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import TermCloud from "../../components/TermCloud.astro";
import { getAllPosts, getTerms } from "../../lib/posts";
import { siteConfig } from "../../lib/site";

const terms = getTerms(await getAllPosts(), "series");
const taxonomyConfig = siteConfig.taxonomy ?? {};
---

<BaseLayout title="Series" description="All post series and collections.">
  {taxonomyConfig.showHero !== false && <PageHeader eyebrow="Series" title="Series" description="Series are organized through front matter `series` and `seriesOrder` fields." />}
  <section class="content-section">
    <TermCloud terms={terms} basePath="/series" showCount={taxonomyConfig.showTermCount !== false} cardView={taxonomyConfig.cardView === true} />
  </section>
</BaseLayout>
