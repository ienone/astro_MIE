---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, getPostsByTermSlug, getTerms } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTerms(posts, "series").map((item) => ({
    params: { slug: item.slug },
    props: {
      term: item.term,
      posts: getPostsByTermSlug(posts, "series", item.slug).sort(
        (a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999) || a.data.date.getTime() - b.data.date.getTime()
      )
    }
  }));
}

const { term, posts } = Astro.props;
---

<BaseLayout title={`Series: ${term}`} description={`Posts in the ${term} series.`}>
  <PageHeader eyebrow="Series" title={term} description={`${posts.length} posts.`} />
  <section class="content-section">
    <PostList posts={posts} compact />
  </section>
</BaseLayout>
