---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PaginationNav from "../../components/PaginationNav.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, getPageItems, getPostsByTermSlug, getTerms, getTotalPages } from "../../lib/posts";
import { getPagerSize, siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTerms(posts, "series").map((item) => ({
    params: { slug: item.slug },
    props: {
      term: item.term,
      posts: getPostsByTermSlug(posts, "series", item.slug).sort(
        (a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999) || a.data.date.getTime() - b.data.date.getTime()
      )
    }
  }));
}

const { term, posts } = Astro.props;
const termConfig = siteConfig.term ?? {};
const pageSize = getPagerSize();
const pagePosts = getPageItems(posts, 1, pageSize);
const totalPages = getTotalPages(posts, pageSize);
---

<BaseLayout title={`Series: ${term}`} description={`Posts in the ${term} series.`}>
  {termConfig.showHero !== false && <PageHeader eyebrow="Series" title={term} description={`${posts.length} posts.`} />}
  <section class="content-section">
    <PostList posts={pagePosts} compact={termConfig.cardView !== true} groupByYear={termConfig.groupByYear === true} cardViewScreenWidth={termConfig.cardViewScreenWidth === true} />
    <PaginationNav currentPage={1} totalPages={totalPages} basePath={`/series/${Astro.params.slug}`} />
  </section>
</BaseLayout>
