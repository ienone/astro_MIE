---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, getPostsByTermSlug, getTerms } from "../../lib/posts";
import { siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTerms(posts, "categories").map((item) => ({
    params: { slug: item.slug },
    props: { term: item.term, posts: getPostsByTermSlug(posts, "categories", item.slug) }
  }));
}

const { term, posts } = Astro.props;
const termConfig = siteConfig.term ?? {};
---

<BaseLayout title={`Category: ${term}`} description={`Posts in the ${term} category.`}>
  {termConfig.showHero !== false && <PageHeader eyebrow="Category" title={term} description={`${posts.length} posts.`} />}
  <section class="content-section">
    <PostList posts={posts} compact={termConfig.cardView !== true} groupByYear={termConfig.groupByYear === true} cardViewScreenWidth={termConfig.cardViewScreenWidth === true} />
  </section>
</BaseLayout>
