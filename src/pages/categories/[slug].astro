---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PaginationNav from "../../components/PaginationNav.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, getPageItems, getPostsByTermSlug, getTermMaterialColorStyle, getTerms, getTotalPages } from "../../lib/posts";
import { getPagerSize, siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTerms(posts, "categories").map((item) => ({
    params: { slug: item.slug },
    props: { term: item.term, posts: getPostsByTermSlug(posts, "categories", item.slug) }
  }));
}

const { term, posts } = Astro.props;
const termConfig = siteConfig.term ?? {};
const pageSize = getPagerSize();
const pagePosts = getPageItems(posts, 1, pageSize);
const totalPages = getTotalPages(posts, pageSize);
---

<BaseLayout title={`Category: ${term}`} description={`Posts in the ${term} category.`}>
  {termConfig.showHero !== false && <PageHeader eyebrow="Category" title={term} description={`${posts.length} posts.`} style={getTermMaterialColorStyle("categories", term)} />}
  <section class="content-section">
    <PostList posts={pagePosts} compact={termConfig.cardView !== true} groupByYear={termConfig.groupByYear === true} cardViewScreenWidth={termConfig.cardViewScreenWidth === true} />
    <PaginationNav currentPage={1} totalPages={totalPages} basePath={`/categories/${Astro.params.slug}`} />
  </section>
</BaseLayout>
