---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostList from "../../components/PostList.astro";
import {
  getAllPosts,
  getConfiguredSectionKeys,
  getSectionDescription,
  getSectionLabel,
  getSectionMaterialColorStyle,
  postMatchesSection
} from "../../lib/posts";
import { siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const sections = getConfiguredSectionKeys(posts);

  return sections.map((section) => ({
    params: { section },
    props: {
      section,
      posts: posts.filter((post) => postMatchesSection(post, section))
    }
  }));
}

const { section, posts } = Astro.props;
const title = getSectionLabel(section);
const description = getSectionDescription(section) || `Posts in the ${title} section.`;
const termConfig = siteConfig.term ?? {};
const postListVariant = termConfig.cardView === true ? "grid" : "compact-grid";
---

<BaseLayout title={title} description={description}>
  {termConfig.showHero !== false && <PageHeader eyebrow="Section" title={title} description={`${description} ${posts.length} posts.`} style={getSectionMaterialColorStyle(section)} />}
  <section class="content-section">
    <PostList posts={posts} variant={postListVariant} groupByYear={termConfig.groupByYear === true} cardViewScreenWidth={termConfig.cardViewScreenWidth === true} />
  </section>
</BaseLayout>
