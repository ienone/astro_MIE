---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Ripple from "../../components/material/Ripple.astro";
import { getAllPosts, getCollectionMaterialColorStyle, getConfiguredSectionKeys, getSectionLabel, getSectionMaterialColorStyle, postMatchesSection } from "../../lib/posts";
import { siteConfig } from "../../lib/site";

const posts = await getAllPosts();
const sections = getConfiguredSectionKeys(posts).map((section) => [
  section,
  posts.filter((post) => postMatchesSection(post, section)).length
] as const);
const taxonomyConfig = siteConfig.taxonomy ?? {};
---

<BaseLayout title="Sections" description="Browse posts by configured content section.">
  {taxonomyConfig.showHero !== false && <PageHeader eyebrow="Sections" title="Sections" description="Sections come from site configuration and can appear in top-level or dropdown navigation." style={getCollectionMaterialColorStyle("sections")} />}
  <section class="content-section">
    <div class="term-grid">
      {sections.map(([section, count]) => <a class="term-card mie-dynamic-color" href={`/sections/${section}/`} style={getSectionMaterialColorStyle(section)}><Ripple /><span>{getSectionLabel(section)}</span>{taxonomyConfig.showTermCount !== false && <strong>{count}</strong>}</a>)}
    </div>
  </section>
</BaseLayout>
