---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import PostList from "../components/PostList.astro";
import MaterialChip from "../components/material/Chip.astro";
import MaterialIconButton from "../components/material/IconButton.astro";
import Ripple from "../components/material/Ripple.astro";
import { getAllPosts, getTermMaterialColorStyle, getTerms } from "../lib/posts";
import { isExternalLink, siteConfig } from "../lib/site";

const posts = await getAllPosts();
const homepage = siteConfig.homepage ?? {};
const recent = posts.slice(0, homepage.showRecentItems ?? 6);
const tags = getTerms(posts, "tags").slice(0, 12);

function getSocialText(link: { label: string; displayLabel?: string }) {
  return link.displayLabel || link.label;
}
---

<BaseLayout>
  <section class="home-hero">
    <OptimizedImage class="home-hero-bg" src={siteConfig.assets.homeBackground} alt="" loading="eager" decoding="async" fetchpriority="high" widths={[960, 1440, 1920]} sizes="100vw" fit="cover" />
    <div class="home-hero-scrim"></div>
    <div class="home-hero-content">
      {siteConfig.author.avatar && <OptimizedImage class="avatar" src={siteConfig.author.avatar} alt="" width={110} height={110} decoding="async" />}
      <p class="eyebrow">{homepage.eyebrow ?? "Personal static blog"}</p>
      <h1>{siteConfig.name}</h1>
      <p>{siteConfig.author.headline}</p>
      <div class="hero-links social-links" aria-label="社交平台">
        {
          siteConfig.author.links.map((link) => (
            <a
              class="social-link"
              href={link.href}
              target={isExternalLink(link.href) ? "_blank" : undefined}
              rel={isExternalLink(link.href) ? "noopener noreferrer" : undefined}
              aria-label={link.displayLabel ? `${link.label}: ${link.displayLabel}` : link.label}
              title={getSocialText(link)}
            >
              <Ripple />
              <Icon name={link.icon} />
              <span class="social-link__label">{getSocialText(link)}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {
    homepage.showRecent !== false && (
      <section class="content-section">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Latest</p>
            <h2>Latest posts</h2>
          </div>
          <MaterialIconButton
            class="section-icon-link"
            icon="arrow-right"
            href={homepage.showMoreLinkDest ?? "/posts/"}
            aria-label="View all posts"
            title="View all posts"
          />
        </div>
        <PostList posts={recent} />
      </section>
    )
  }

  <section class="content-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Browse</p>
        <h2>Popular tags</h2>
      </div>
      <MaterialIconButton class="section-icon-link" icon="arrow-right" href="/tags/" aria-label="View all tags" title="View all tags" />
    </div>
    <div class="tag-strip">
      {
        tags.map((tag) => (
          <MaterialChip class="tag-chip mie-dynamic-color" href={`/tags/${tag.slug}/`} style={getTermMaterialColorStyle("tags", tag.term)} elevated>
            <span>{tag.term}</span>
            <span class="tag-count">{tag.count}</span>
          </MaterialChip>
        ))
      }
    </div>
  </section>
</BaseLayout>
