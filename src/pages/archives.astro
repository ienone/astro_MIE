---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PostListItem from "../components/PostListItem.astro";
import { getAllPosts, getArchiveGroups, getCollectionMaterialColorStyle } from "../lib/posts";

const groups = getArchiveGroups(await getAllPosts());
---

<BaseLayout title="Archives" description="A yearly archive of published posts.">
  <PageHeader eyebrow="Archives" title="Archives" description="All posts grouped by publication year." style={getCollectionMaterialColorStyle("archives")} />
  <section class="archive-list">
    {
      groups.map(([year, posts]) => (
        <section class="archive-year">
          <h2>{year}</h2>
          <div>
            {posts.map((post) => (
              <PostListItem post={post} />
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
