---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Ripple from "../components/material/Ripple.astro";
import { formatDate, getAllPosts, getArchiveGroups, getCollectionMaterialColorStyle, getPostMaterialColorStyle, getPostUrl } from "../lib/posts";

const groups = getArchiveGroups(await getAllPosts());
---

<BaseLayout title="Archives" description="A yearly archive of published posts.">
  <PageHeader eyebrow="Archives" title="Archives" description="All posts grouped by publication year." style={getCollectionMaterialColorStyle("archives")} />
  <section class="archive-list">
    {
      groups.map(([year, posts]) => (
        <section class="archive-year">
          <h2>{year}</h2>
          <div>
            {posts.map((post) => (
              <a class="archive-item mie-dynamic-color" href={getPostUrl(post)} style={getPostMaterialColorStyle(post)}>
                <Ripple />
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                <span>{post.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
