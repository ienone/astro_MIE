---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PaginationNav from "../../components/PaginationNav.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, getPageItems, getPostsByTermSlug, getTermMaterialColorStyle, getTerms, getTotalPages } from "../../lib/posts";
import { getPagerSize, siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTerms(posts, "tags").map((item) => ({
    params: { slug: item.slug },
    props: { term: item.term, posts: getPostsByTermSlug(posts, "tags", item.slug) }
  }));
}

const { term, posts } = Astro.props;
const termConfig = siteConfig.term ?? {};
const pageSize = getPagerSize();
const pagePosts = getPageItems(posts, 1, pageSize);
const totalPages = getTotalPages(posts, pageSize);
const postListVariant = termConfig.cardView === true ? "grid" : "compact-grid";
---

<BaseLayout title={`Tag: ${term}`} description={`Posts tagged ${term}.`}>
  {termConfig.showHero !== false && <PageHeader eyebrow="Tag" title={term} description={`${posts.length} posts.`} style={getTermMaterialColorStyle("tags", term)} />}
  <section class="content-section">
    <PostList posts={pagePosts} variant={postListVariant} groupByYear={termConfig.groupByYear === true} cardViewScreenWidth={termConfig.cardViewScreenWidth === true} />
    <PaginationNav currentPage={1} totalPages={totalPages} basePath={`/tags/${Astro.params.slug}`} />
  </section>
</BaseLayout>
