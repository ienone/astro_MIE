---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, getPostsByTermSlug, getTerms } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTerms(posts, "tags").map((item) => ({
    params: { slug: item.slug },
    props: { term: item.term, posts: getPostsByTermSlug(posts, "tags", item.slug) }
  }));
}

const { term, posts } = Astro.props;
---

<BaseLayout title={`Tag: ${term}`} description={`Posts tagged ${term}.`}>
  <PageHeader eyebrow="Tag" title={term} description={`${posts.length} posts.`} />
  <section class="content-section">
    <PostList posts={posts} compact />
  </section>
</BaseLayout>
