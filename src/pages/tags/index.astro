---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import TermCloud from "../../components/TermCloud.astro";
import { getAllPosts, getTerms } from "../../lib/posts";
import { siteConfig } from "../../lib/site";

const terms = getTerms(await getAllPosts(), "tags");
const taxonomyConfig = siteConfig.taxonomy ?? {};
---

<BaseLayout title="Tags" description="All generated post tags.">
  {taxonomyConfig.showHero !== false && <PageHeader eyebrow="Tags" title="Tags" description="Tags are generated from post front matter." />}
  <section class="content-section">
    <TermCloud terms={terms} basePath="/tags" showCount={taxonomyConfig.showTermCount !== false} cardView={taxonomyConfig.cardView === true} />
  </section>
</BaseLayout>
