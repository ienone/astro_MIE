---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<BaseLayout title="搜索" description="使用 Pagefind 静态索引搜索文章。">
  <PageHeader eyebrow="Search" title="搜索" description="搜索由 Pagefind 生成的静态文章索引，支持标题、摘要和正文匹配。" />
  <section class="content-section search-page">
    <input data-search-page-input type="search" placeholder="输入关键词" autocomplete="off" />
    <div class="search-results inline" data-search-page-results></div>
  </section>
</BaseLayout>
