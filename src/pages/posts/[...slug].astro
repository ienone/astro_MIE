---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import OptimizedImage from "../../components/OptimizedImage.astro";
import PostCard from "../../components/PostCard.astro";
import ShareLinks from "../../components/ShareLinks.astro";
import Toc from "../../components/Toc.astro";
import Icon from "../../components/Icon.astro";
import {
  formatDate,
  getAllPosts,
  getPostEditUrl,
  getPostBackgroundImage,
  getPostImage,
  getPostImagePosition,
  getPostSlug,
  getPostSummary,
  getPostThemeColor,
  getPostTransitionSetName,
  getPostTransitionName,
  getPostUrl,
  getRelatedPosts,
  readingTime,
  termToSlug,
  wordCount
} from "../../lib/posts";
import { siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const posts = await getAllPosts();
const index = posts.findIndex((item) => item.id === post.id);
const newer = index > 0 ? posts[index - 1] : undefined;
const older = index >= 0 ? posts[index + 1] : undefined;
const related = getRelatedPosts(posts, post);
const image = getPostImage(post);
const backgroundImage = getPostBackgroundImage(post);
const articleStyle = { "--post-theme": getPostThemeColor(post) };
const imagePosition = getPostImagePosition(post);
const postSummary = getPostSummary(post);
const backgroundImageWidth = siteConfig.assets.backgroundImageWidth ?? 1920;
const backgroundImageWidths = [960, 1440, backgroundImageWidth].filter((width, index, widths) => width > 0 && widths.indexOf(width) === index);
const articleConfig = siteConfig.article ?? {};
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const showHero = articleConfig.showHero !== false;
const showBreadcrumbs = articleConfig.showBreadcrumbs !== false;
const showAuthor = articleConfig.showAuthor !== false;
const showDraftLabel = articleConfig.showDraftLabel !== false;
const showEdit = articleConfig.showEdit === true;
const showDate = articleConfig.showDate !== false;
const showDateUpdated = articleConfig.showDateUpdated !== false;
const showWordCount = articleConfig.showWordCount !== false;
const showReadingTime = articleConfig.showReadingTime !== false;
const showTaxonomies = articleConfig.showTaxonomies === true;
const showPostPagination = articleConfig.showPagination !== false;
const invertPagination = articleConfig.invertPagination === true;
const showToc = siteConfig.features?.smartToc !== false && articleConfig.showTableOfContents !== false;
const showZenMode = articleConfig.showZenMode !== false;
const sharingLinks = articleConfig.sharingLinks ?? [];
const hideUnfocusedTocChildren = siteConfig.features?.smartTocHideUnfocusedChildren !== false;
const tocSource = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
let tocGroupCount = 0;
for (const heading of tocSource) {
  if (heading.depth === 2 || tocGroupCount === 0) tocGroupCount += 1;
}
const hasToc = showToc && tocGroupCount > 1;
const transitionSetName = getPostTransitionSetName(post);
const coverTransitionName = getPostTransitionName(post, "cover");
const titleTransitionName = getPostTransitionName(post, "title");
const seriesName = post.data.series[0];
const seriesPosts = seriesName
  ? posts
      .filter((item) => item.data.series.includes(seriesName))
      .sort((a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999) || a.data.date.getTime() - b.data.date.getTime())
  : [];
const previousPost = invertPagination ? newer : older;
const nextPost = invertPagination ? older : newer;
const editUrl = getPostEditUrl(post);
---

<BaseLayout
  title={post.data.seo?.title || post.data.title}
  description={post.data.seo?.description || postSummary || siteConfig.description}
  image={post.data.seo?.ogImage || image}
  type="article"
  currentSection={post.data.section}
>
  <article class="article-shell" style={articleStyle} data-article-shell data-pagefind-body>
    <div class="reading-progress" data-reading-progress aria-hidden="true"></div>
    <header
      class="article-hero"
      data-route-shared-set={transitionSetName}
      data-route-shared-context="article"
      data-route-shared-target-context="card"
      data-route-shared-default-source="true"
      data-route-shared-default-back="true"
    >
      {showHero && backgroundImage && <OptimizedImage class="article-background" src={backgroundImage} alt="" loading="lazy" decoding="async" fetchpriority="low" widths={backgroundImageWidths} sizes="100vw" fit="cover" />}
      <div class="article-hero-content">
        {showBreadcrumbs && <a class="breadcrumb" href="/posts/">Posts</a>}
        {showDraftLabel && post.data.draft && <p class="draft-label">Draft</p>}
        <h1
          class="post-title-transition"
          data-post-transition-title={titleTransitionName}
          data-route-shared
          data-route-shared-set={transitionSetName}
          data-route-shared-name={titleTransitionName}
          data-route-shared-group="post-title"
          data-route-shared-context="article"
          data-route-shared-target-context="card"
          data-route-shared-exit="fade"
          data-route-shared-suppress-visual="true"
          data-pagefind-meta="title"
          transition:name={titleTransitionName}
        >
          {post.data.title}
        </h1>
        {postSummary && <p class="article-description" data-pagefind-meta="description">{postSummary}</p>}
        {showAuthor && (
          <div class="article-author" data-pagefind-ignore>
            {siteConfig.author.avatar && <img src={siteConfig.author.avatar} alt="" loading="lazy" decoding="async" />}
            <div>
              <span>Written by</span>
              <strong>{siteConfig.author.displayName || siteConfig.author.name}</strong>
              {siteConfig.author.bio && <p>{siteConfig.author.bio}</p>}
            </div>
          </div>
        )}
        <div class="article-meta">
          {showDate && <span>{formatDate(post.data.date)}</span>}
          {showDateUpdated && post.data.updatedDate && <span>Updated {formatDate(post.data.updatedDate)}</span>}
          {showWordCount && <span>{wordCount(post.body).toLocaleString("en-US")} words</span>}
          {showReadingTime && <span>{readingTime(post.body)}</span>}
        </div>
        {showTaxonomies && (
          <div class="taxonomy-row">
            {post.data.categories.map((category) => <a href={`/categories/${termToSlug(category)}/`}>{category}</a>)}
            {post.data.tags.map((tag) => <a href={`/tags/${termToSlug(tag)}/`}>{tag}</a>)}
          </div>
        )}
        {hasToc && showZenMode && (
          <div class="article-actions" data-pagefind-ignore>
            <button class="article-view-toggle" type="button" data-toc-toggle aria-controls="article-toc" aria-pressed="false" aria-label="隐藏目录">
              <Icon name="list-tree" />
              <span data-toc-toggle-label>沉浸阅读</span>
            </button>
            {showEdit && editUrl && <a class="article-view-toggle" href={editUrl} target="_blank" rel="noopener noreferrer"><Icon name="edit" /><span>编辑本文</span></a>}
          </div>
        )}
        {(!hasToc || !showZenMode) && showEdit && editUrl && (
          <div class="article-actions" data-pagefind-ignore>
            <a class="article-view-toggle" href={editUrl} target="_blank" rel="noopener noreferrer"><Icon name="edit" /><span>编辑本文</span></a>
          </div>
        )}
      </div>
      {showHero && image && (
        <figure class="article-cover">
          <div
            class="post-cover-transition"
            data-post-transition-cover={coverTransitionName}
            data-route-shared
            data-route-shared-set={transitionSetName}
            data-route-shared-name={coverTransitionName}
            data-route-shared-group="post-cover"
            data-route-shared-context="article"
            data-route-shared-target-context="card"
            data-route-shared-exit="fade"
            data-route-shared-suppress-visual="true"
            transition:name={coverTransitionName}
          >
            <OptimizedImage
              src={image}
              alt={post.data.media?.alt || post.data.title}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 980px) 420px, 100vw"
              fit="cover"
              position={imagePosition}
              style={{ objectPosition: imagePosition }}
            />
          </div>
        </figure>
      )}
    </header>

    <div class="article-layout" data-article-layout data-toc-enabled={String(hasToc)} data-toc-state={hasToc ? "visible" : "disabled"}>
      {hasToc && <Toc id="article-toc" headings={headings} hideUnfocusedChildren={hideUnfocusedTocChildren} />}
      <div class="article-main">
        {seriesPosts.length > 1 && (
          <aside class="series-callout" data-pagefind-ignore>
            <p>Series: <a href={`/series/${termToSlug(seriesName)}/`}>{seriesName}</a></p>
            <ol>
              {seriesPosts.map((item) => (
                <li class={item.id === post.id ? "current" : ""}>
                  <a href={getPostUrl(item)}>{item.data.title}</a>
                </li>
              ))}
            </ol>
          </aside>
        )}

        <div class="prose">
          <Content />
        </div>

        <ShareLinks title={post.data.title} url={canonicalUrl} links={sharingLinks} />

        {showPostPagination && (
          <nav class="post-pagination" aria-label="Previous and next posts" data-pagefind-ignore>
            {previousPost && <a href={getPostUrl(previousPost)} style={{ "--post-theme": getPostThemeColor(previousPost) }}><span>{invertPagination ? "Newer post" : "Older post"}</span>{previousPost.data.title}</a>}
            {nextPost && <a href={getPostUrl(nextPost)} style={{ "--post-theme": getPostThemeColor(nextPost) }}><span>{invertPagination ? "Older post" : "Newer post"}</span>{nextPost.data.title}</a>}
          </nav>
        )}

        {related.length > 0 && (
          <section class="related-section" data-pagefind-ignore>
            <div class="section-heading">
              <div>
                <p class="eyebrow">Related</p>
                <h2>Related posts</h2>
              </div>
            </div>
            <div class="post-grid compact">
              {related.map((item) => <PostCard post={item} compact />)}
            </div>
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
